<Window x:Class="GeminiDesk.SubscriptionComparisonDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="구독과 비교하기"
        Width="760"
        Height="740"
        MinWidth="650"
        MinHeight="620"
        ShowInTaskbar="False"
        WindowStartupLocation="CenterOwner"
        FontFamily="Segoe UI Variable Text, Malgun Gothic"
        Background="#FFF8F7FC">
    <Window.Resources>
        <SolidColorBrush x:Key="InkBrush" Color="#FF29263B" />
        <SolidColorBrush x:Key="MutedBrush" Color="#FF797487" />
        <SolidColorBrush x:Key="PrimaryBrush" Color="#FF7567E8" />
        <SolidColorBrush x:Key="PrimarySoftBrush" Color="#FFEDEAFF" />
        <SolidColorBrush x:Key="BorderBrush" Color="#FFE9E5F1" />

        <Style x:Key="CloseButton" TargetType="Button">
            <Setter Property="Height" Value="39" />
            <Setter Property="Padding" Value="18,6" />
            <Setter Property="Background" Value="{StaticResource PrimaryBrush}" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="ButtonBorder"
                                Padding="{TemplateBinding Padding}"
                                Background="{TemplateBinding Background}"
                                CornerRadius="13">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Opacity" Value="0.85" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Opacity" Value="0.68" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Margin="26,23,26,20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <StackPanel>
                <StackPanel Orientation="Horizontal">
                    <TextBlock FontSize="25"
                               FontWeight="Bold"
                               Foreground="{StaticResource InkBrush}"
                               Text="구독과 비교하기" />
                    <Image Width="32"
                           Height="32"
                           Margin="8,-2,0,0"
                           VerticalAlignment="Center"
                           Stretch="Uniform"
                           Source="/GeminiDesk;component/Assets/bunny-mascot.png" />
                </StackPanel>
                <TextBlock x:Name="ComparisonMonthText"
                           Margin="1,6,0,0"
                           FontSize="12"
                           Foreground="{StaticResource MutedBrush}"
                           Text="2026년 7월 사용량 기준" />
            </StackPanel>
            <Border Grid.Column="1"
                    Padding="13,7"
                    VerticalAlignment="Center"
                    Background="{StaticResource PrimarySoftBrush}"
                    CornerRadius="12">
                <TextBlock x:Name="ExchangeRateText"
                           FontSize="10.5"
                           FontWeight="SemiBold"
                           Foreground="#FF5D51C6"
                           Text="ECB 환율 기준" />
            </Border>
        </Grid>

        <Border Grid.Row="1"
                Margin="0,17,0,14"
                Padding="15,12"
                Background="#FFFFF0F5"
                CornerRadius="14">
            <TextBlock FontSize="11"
                       Foreground="#FF9A4F6A"
                       Text="공홈 구독은 Bunny Desk의 API 요금을 대신 내주지 않아요. 금액과 사용 습관을 비교하기 위한 참고용이에요."
                       TextWrapping="Wrap" />
        </Border>

        <ScrollViewer Grid.Row="2"
                      HorizontalScrollBarVisibility="Disabled"
                      VerticalScrollBarVisibility="Auto">
            <ItemsControl x:Name="ComparisonItems">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Margin="0,0,0,12"
                                Padding="18"
                                Background="White"
                                BorderBrush="{StaticResource BorderBrush}"
                                BorderThickness="1"
                                CornerRadius="19">
                            <StackPanel>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <Border Width="40"
                                            Height="40"
                                            Margin="0,0,12,0"
                                            Background="{StaticResource PrimarySoftBrush}"
                                            CornerRadius="13">
                                        <TextBlock HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"
                                                   FontSize="18"
                                                   Foreground="{StaticResource PrimaryBrush}"
                                                   Text="{Binding Icon}" />
                                    </Border>
                                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                        <TextBlock FontSize="15"
                                                   FontWeight="Bold"
                                                   Foreground="{StaticResource InkBrush}"
                                                   Text="{Binding ProviderName}" />
                                        <TextBlock Margin="0,2,0,0"
                                                   FontSize="10"
                                                   Foreground="{StaticResource MutedBrush}"
                                                   Text="이번 달 API와 공홈 개인 구독 비교" />
                                    </StackPanel>
                                    <Border Grid.Column="2"
                                            Padding="10,5"
                                            VerticalAlignment="Center"
                                            Background="#FFF4F2F7"
                                            CornerRadius="9">
                                        <TextBlock FontSize="10"
                                                   FontWeight="SemiBold"
                                                   Foreground="{StaticResource MutedBrush}"
                                                   Text="{Binding ApiUsageLabel}" />
                                    </Border>
                                </Grid>

                                <Grid Margin="0,14,0,12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="12" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <Border Padding="13,11"
                                            Background="#FFFCFBFE"
                                            CornerRadius="12">
                                        <StackPanel>
                                            <TextBlock FontSize="10"
                                                       Foreground="{StaticResource MutedBrush}"
                                                       Text="Bunny Desk API" />
                                            <TextBlock Margin="0,4,0,0"
                                                       FontSize="13"
                                                       FontWeight="Bold"
                                                       Foreground="{StaticResource InkBrush}"
                                                       Text="{Binding ApiCostLabel}"
                                                       TextWrapping="Wrap" />
                                        </StackPanel>
                                    </Border>
                                    <Border Grid.Column="2"
                                            Padding="13,11"
                                            Background="#FFFCFBFE"
                                            CornerRadius="12">
                                        <StackPanel>
                                            <DockPanel LastChildFill="False">
                                                <TextBlock FontSize="10"
                                                           Foreground="{StaticResource MutedBrush}"
                                                           Text="{Binding PlanName}" />
                                                <TextBlock DockPanel.Dock="Right"
                                                           FontSize="9.5"
                                                           Foreground="{StaticResource MutedBrush}"
                                                           Text="{Binding SubscriptionUsdLabel}" />
                                            </DockPanel>
                                            <TextBlock Margin="0,4,0,0"
                                                       FontSize="13"
                                                       FontWeight="Bold"
                                                       Foreground="{StaticResource InkBrush}"
                                                       Text="{Binding SubscriptionCostLabel}"
                                                       TextWrapping="Wrap" />
                                        </StackPanel>
                                    </Border>
                                </Grid>

                                <Border Padding="13,10" CornerRadius="12">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Background" Value="#FFEDF8F2" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding RecommendationKind}" Value="subscription">
                                                    <Setter Property="Background" Value="#FFFFEAF2" />
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding RecommendationKind}" Value="similar">
                                                    <Setter Property="Background" Value="{StaticResource PrimarySoftBrush}" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <StackPanel>
                                        <TextBlock FontSize="12"
                                                   FontWeight="Bold"
                                                   Foreground="{StaticResource InkBrush}"
                                                   Text="{Binding RecommendationTitle}" />
                                        <TextBlock Margin="0,3,0,0"
                                                   FontSize="10.5"
                                                   Foreground="{StaticResource MutedBrush}"
                                                   Text="{Binding RecommendationDetail}"
                                                   TextWrapping="Wrap" />
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <Grid Grid.Row="3" Margin="1,13,1,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <TextBlock x:Name="PriceReferenceText"
                       VerticalAlignment="Center"
                       FontSize="9.5"
                       Foreground="{StaticResource MutedBrush}"
                       Text="공식 월간 정가·세전 기준 · 지역별 가격, 무료 한도, 모델과 사용 한도 차이는 반영되지 않아요."
                       TextWrapping="Wrap" />
            <Button Grid.Column="1"
                    Margin="18,0,0,0"
                    Style="{StaticResource CloseButton}"
                    Click="CloseButton_Click"
                    IsCancel="True"
                    Content="확인" />
        </Grid>
    </Grid>
</Window>
