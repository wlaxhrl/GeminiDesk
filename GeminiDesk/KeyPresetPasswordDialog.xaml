<Window x:Class="GeminiDesk.KeyPresetPasswordDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="키 프리셋 비밀번호"
        Width="460"
        Height="360"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        WindowStartupLocation="CenterOwner"
        FontFamily="Segoe UI Variable Text, Malgun Gothic"
        Background="#FFF8F7FC">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <StackPanel>
            <TextBlock x:Name="HeadingText"
                       FontSize="20"
                       FontWeight="Bold"
                       Foreground="#FF29263B"
                       Text="프리셋 비밀번호" />
            <TextBlock x:Name="DescriptionText"
                       Margin="0,6,0,0"
                       FontSize="11.5"
                       Foreground="#FF797487"
                       TextWrapping="Wrap" />
        </StackPanel>

        <TextBlock Grid.Row="1"
                   Margin="1,17,0,7"
                   FontSize="12"
                   FontWeight="SemiBold"
                   Foreground="#FF29263B"
                   Text="비밀번호" />
        <Border Grid.Row="2"
                Height="42"
                Background="White"
                BorderBrush="#FFE3DFF0"
                BorderThickness="1"
                CornerRadius="12">
            <PasswordBox x:Name="PasswordBox"
                         MaxLength="128"
                         Padding="12,8"
                         VerticalContentAlignment="Center"
                         Background="Transparent"
                         BorderThickness="0"
                         Foreground="#FF29263B" />
        </Border>

        <StackPanel x:Name="ConfirmPasswordPanel" Grid.Row="3">
            <TextBlock Margin="1,12,0,7"
                       FontSize="12"
                       FontWeight="SemiBold"
                       Foreground="#FF29263B"
                       Text="비밀번호 확인" />
            <Border Height="42"
                    Background="White"
                    BorderBrush="#FFE3DFF0"
                    BorderThickness="1"
                    CornerRadius="12">
                <PasswordBox x:Name="ConfirmPasswordBox"
                             MaxLength="128"
                             Padding="12,8"
                             VerticalContentAlignment="Center"
                             Background="Transparent"
                             BorderThickness="0"
                             Foreground="#FF29263B" />
            </Border>
        </StackPanel>

        <TextBlock x:Name="ErrorText"
                   Grid.Row="4"
                   Margin="1,9,0,0"
                   FontSize="11"
                   Foreground="#FFC0475D"
                   TextWrapping="Wrap"
                   Visibility="Collapsed" />

        <StackPanel Grid.Row="5"
                    Margin="0,16,0,0"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Bottom"
                    Orientation="Horizontal">
            <Button Width="86"
                    Height="35"
                    Margin="0,0,8,0"
                    IsCancel="True"
                    Content="취소" />
            <Button Width="104"
                    Height="35"
                    Background="#FF7567E8"
                    BorderThickness="0"
                    Click="ConfirmButton_Click"
                    Foreground="White"
                    IsDefault="True"
                    Content="확인" />
        </StackPanel>
    </Grid>
</Window>
