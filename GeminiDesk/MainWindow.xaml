<Window x:Class="GeminiDesk.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:GeminiDesk"
        xmlns:mdxaml="clr-namespace:MdXaml;assembly=MdXaml"
        Title="GeminiDesk"
        Width="1180"
        Height="760"
        MinWidth="900"
        MinHeight="620"
        WindowStartupLocation="CenterScreen"
        FontFamily="Segoe UI Variable Text, Malgun Gothic"
        Background="#FFF8F7FC">
    <Window.Resources>
        <local:AttachmentPreviewConverter x:Key="AttachmentPreviewConverter" />

        <SolidColorBrush x:Key="InkBrush" Color="#FF29263B" />
        <SolidColorBrush x:Key="MutedBrush" Color="#FF797487" />
        <SolidColorBrush x:Key="PrimaryBrush" Color="#FF7567E8" />
        <SolidColorBrush x:Key="PrimarySoftBrush" Color="#FFEDEAFF" />
        <SolidColorBrush x:Key="PinkSoftBrush" Color="#FFFFEAF2" />
        <SolidColorBrush x:Key="BorderBrush" Color="#FFE9E5F1" />
        <SolidColorBrush x:Key="CardBrush" Color="#FFFFFFFF" />

        <Style TargetType="{x:Type Paragraph}">
            <Setter Property="FontFamily" Value="Segoe UI Variable Text, Malgun Gothic" />
            <Setter Property="FontSize" Value="15" />
            <Setter Property="LineHeight" Value="30" />
            <Setter Property="Margin" Value="0,3,0,15" />
        </Style>

        <Style TargetType="{x:Type ListItem}">
            <Setter Property="Margin" Value="0,2,0,5" />
        </Style>

        <Style x:Key="PillButton" TargetType="Button">
            <Setter Property="Height" Value="38" />
            <Setter Property="Padding" Value="15,7" />
            <Setter Property="Background" Value="White" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Foreground" Value="{StaticResource InkBrush}" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="ButtonBorder"
                                Padding="{TemplateBinding Padding}"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="13">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Opacity" Value="0.84" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Opacity" Value="0.68" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="ButtonBorder" Property="Opacity" Value="0.42" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PrimaryButton" TargetType="Button" BasedOn="{StaticResource PillButton}">
            <Setter Property="Background" Value="{StaticResource PrimaryBrush}" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Foreground" Value="White" />
        </Style>

        <Style x:Key="SoftButton" TargetType="Button" BasedOn="{StaticResource PillButton}">
            <Setter Property="Background" Value="{StaticResource PrimarySoftBrush}" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Foreground" Value="#FF5D51C6" />
        </Style>

        <Style x:Key="ResponseActionButton" TargetType="Button">
            <Setter Property="Width" Value="30" />
            <Setter Property="Height" Value="28" />
            <Setter Property="Margin" Value="0,0,3,0" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Foreground" Value="{StaticResource MutedBrush}" />
            <Setter Property="FontFamily" Value="Segoe Fluent Icons, Segoe MDL2 Assets" />
            <Setter Property="FontSize" Value="15" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="ToolTipService.InitialShowDelay" Value="300" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="ActionButtonBorder"
                                Background="{TemplateBinding Background}"
                                CornerRadius="9">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ActionButtonBorder" Property="Background" Value="{StaticResource PrimarySoftBrush}" />
                                <Setter Property="Foreground" Value="{StaticResource PrimaryBrush}" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="ActionButtonBorder" Property="Opacity" Value="0.65" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.35" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ModelPickerButton" TargetType="Button" BasedOn="{StaticResource SoftButton}">
            <Setter Property="Height" Value="40" />
            <Setter Property="Padding" Value="12,6" />
            <Setter Property="Background" Value="{StaticResource PrimarySoftBrush}" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Foreground" Value="#FF5D51C6" />
            <Setter Property="ToolTipService.InitialShowDelay" Value="250" />
        </Style>

        <Style x:Key="DangerButton" TargetType="Button" BasedOn="{StaticResource PillButton}">
            <Setter Property="Background" Value="#FFFFF1F3" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Foreground" Value="#FFC0475D" />
        </Style>

        <Style x:Key="RoundedTextBox" TargetType="TextBox">
            <Setter Property="Padding" Value="13,10" />
            <Setter Property="Background" Value="#FFFCFBFE" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Foreground" Value="{StaticResource InkBrush}" />
            <Setter Property="CaretBrush" Value="{StaticResource PrimaryBrush}" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border x:Name="InputBorder"
                                Padding="{TemplateBinding Padding}"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="14">
                            <ScrollViewer x:Name="PART_ContentHost" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsKeyboardFocused" Value="True">
                                <Setter TargetName="InputBorder" Property="BorderBrush" Value="{StaticResource PrimaryBrush}" />
                                <Setter TargetName="InputBorder" Property="Background" Value="White" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="InputBorder" Property="Opacity" Value="0.55" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="RoundedPasswordBox" TargetType="PasswordBox">
            <Setter Property="Padding" Value="13,8" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Foreground" Value="{StaticResource InkBrush}" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="258" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0"
                Margin="16,16,0,16"
                CornerRadius="25">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Offset="0" Color="#FFF0EDFF" />
                    <GradientStop Offset="0.55" Color="#FFFFF2F7" />
                    <GradientStop Offset="1" Color="#FFEDF7FF" />
                </LinearGradientBrush>
            </Border.Background>
            <Border.Effect>
                <DropShadowEffect BlurRadius="20" Opacity="0.10" ShadowDepth="5" Color="#FF655B82" />
            </Border.Effect>
            <Grid Margin="18">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <StackPanel Orientation="Horizontal" Margin="2,4,0,20">
                    <Border Width="42" Height="42" Background="{StaticResource PrimaryBrush}" CornerRadius="15">
                        <TextBlock HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   FontSize="21"
                                   Foreground="White"
                                   Text="✦" />
                    </Border>
                    <StackPanel Margin="11,1,0,0">
                        <TextBlock FontSize="19"
                                   FontWeight="Bold"
                                   Foreground="{StaticResource InkBrush}"
                                   Text="GeminiDesk" />
                        <TextBlock Margin="0,2,0,0"
                                   FontSize="11"
                                   Foreground="{StaticResource MutedBrush}"
                                   Text="나만의 작은 AI 공간" />
                    </StackPanel>
                </StackPanel>

                <Button x:Name="NewChatButton"
                        Grid.Row="1"
                        Height="43"
                        Style="{StaticResource PrimaryButton}"
                        Click="NewChatButton_Click"
                        Content="＋  새 대화" />

                <DockPanel Grid.Row="2" Margin="4,22,4,8">
                    <TextBlock FontSize="12"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource MutedBrush}"
                               Text="최근 대화" />
                    <Border DockPanel.Dock="Right"
                            Padding="7,2"
                            Background="#88FFFFFF"
                            CornerRadius="8">
                        <TextBlock FontSize="10"
                                   Foreground="{StaticResource MutedBrush}"
                                   Text="LOCAL" />
                    </Border>
                </DockPanel>

                <ListBox x:Name="ConversationList"
                         Grid.Row="3"
                         ItemsSource="{Binding Conversations}"
                         Background="Transparent"
                         BorderThickness="0"
                         PreviewMouseRightButtonDown="ConversationList_PreviewMouseRightButtonDown"
                         SelectionChanged="ConversationList_SelectionChanged"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem">
                            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                            <Setter Property="Padding" Value="0" />
                            <Setter Property="Margin" Value="0,2" />
                            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="ListBoxItem">
                                        <Border x:Name="HistoryItem"
                                                Padding="11,9"
                                                Background="Transparent"
                                                CornerRadius="13">
                                            <ContentPresenter />
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="HistoryItem" Property="Background" Value="#99FFFFFF" />
                                            </Trigger>
                                            <Trigger Property="IsSelected" Value="True">
                                                <Setter TargetName="HistoryItem" Property="Background" Value="White" />
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </ListBox.ItemContainerStyle>
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <StackPanel>
                                <TextBlock FontWeight="SemiBold"
                                           Foreground="{StaticResource InkBrush}"
                                           Text="{Binding Title}"
                                           TextTrimming="CharacterEllipsis" />
                                <TextBlock Margin="0,3,0,0"
                                           FontSize="10"
                                           Foreground="{StaticResource MutedBrush}"
                                           Text="{Binding UpdatedLabel}" />
                            </StackPanel>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>

                <Button x:Name="DeleteChatButton"
                        Grid.Row="4"
                        Height="36"
                        Margin="0,12,0,0"
                        Style="{StaticResource DangerButton}"
                        Click="DeleteChatButton_Click"
                        Content="선택한 대화 삭제" />

                <StackPanel Grid.Row="5" Margin="2,10,2,0">
                    <DockPanel LastChildFill="False">
                        <TextBlock x:Name="VersionText"
                                   VerticalAlignment="Center"
                                   FontSize="10"
                                   Foreground="{StaticResource MutedBrush}"
                                   Text="v0.1.0" />
                        <Button x:Name="UpdateButton"
                                DockPanel.Dock="Right"
                                Height="28"
                                Padding="10,2"
                                AutomationProperties.Name="GeminiDesk 업데이트 확인"
                                Click="UpdateButton_Click"
                                Content="업데이트 확인"
                                FontSize="10"
                                Style="{StaticResource SoftButton}" />
                    </DockPanel>
                    <TextBlock x:Name="UpdateDetailText"
                               Margin="0,5,0,0"
                               FontSize="9.5"
                               Foreground="{StaticResource MutedBrush}"
                               TextWrapping="Wrap"
                               Visibility="Collapsed" />
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Column="1" Margin="28,22,28,18">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <DockPanel Grid.Row="0" Margin="2,0,2,18">
                <StackPanel x:Name="ModelSelector"
                            DockPanel.Dock="Right"
                            Margin="18,0,0,0"
                            VerticalAlignment="Center">
                    <TextBlock Margin="5,0,0,4"
                               FontSize="10"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource MutedBrush}"
                               Text="사용할 모델" />
                    <Button x:Name="ModelMenuButton"
                            AutomationProperties.Name="사용할 AI 모델 선택"
                            Click="ModelMenuButton_Click"
                            Style="{StaticResource ModelPickerButton}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock x:Name="SelectedModelIcon"
                                       Margin="0,0,6,0"
                                       VerticalAlignment="Center"
                                       FontSize="12"
                                       Text="⚡" />
                            <TextBlock x:Name="SelectedModelName"
                                       VerticalAlignment="Center"
                                       FontFamily="Segoe UI Variable Text, Malgun Gothic"
                                       FontSize="12"
                                       FontWeight="SemiBold"
                                       Text="3.5 Flash" />
                            <Border x:Name="SelectedModelBadge"
                                    Margin="7,0,0,0"
                                    Padding="5,1"
                                    VerticalAlignment="Center"
                                    Background="#FFFFEDF4"
                                    CornerRadius="6"
                                    Visibility="Collapsed">
                                <TextBlock x:Name="SelectedModelBadgeText"
                                           FontSize="8"
                                           FontWeight="Bold"
                                           Foreground="#FFB04C75" />
                            </Border>
                            <TextBlock Margin="8,-2,0,0"
                                       VerticalAlignment="Center"
                                       FontSize="13"
                                       Foreground="{StaticResource MutedBrush}"
                                       Text="⌄" />
                        </StackPanel>
                    </Button>
                </StackPanel>
                <StackPanel>
                    <TextBlock FontSize="27"
                               FontWeight="Bold"
                               Foreground="{StaticResource InkBrush}"
                               Text="오늘은 무엇을 이야기할까요?" />
                    <TextBlock Margin="1,6,0,0"
                               Foreground="{StaticResource MutedBrush}"
                               Text="궁금한 것, 만들고 싶은 것, 아무 이야기나 편하게 꺼내보세요 ✨" />
                </StackPanel>
            </DockPanel>

            <Border Grid.Row="1"
                    Margin="0,0,0,14"
                    Padding="15"
                    Background="{StaticResource CardBrush}"
                    BorderBrush="{StaticResource BorderBrush}"
                    BorderThickness="1"
                    CornerRadius="17">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <Border Grid.Column="0"
                            Width="34"
                            Height="34"
                            Margin="0,0,11,0"
                            Background="{StaticResource PinkSoftBrush}"
                            CornerRadius="11">
                        <TextBlock HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   FontSize="15"
                                   Text="🔑" />
                    </Border>
                    <Border Grid.Column="1"
                            Height="38"
                            Background="#FFFCFBFE"
                            BorderBrush="{StaticResource BorderBrush}"
                            BorderThickness="1"
                            CornerRadius="13">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Border Margin="7,6,4,6"
                                    Padding="8,0"
                                    VerticalAlignment="Stretch"
                                    Background="{StaticResource PinkSoftBrush}"
                                    CornerRadius="7">
                                <TextBlock x:Name="ApiKeyProviderLabel"
                                           VerticalAlignment="Center"
                                           FontSize="10"
                                           FontWeight="SemiBold"
                                           Foreground="#FF9D5E7A"
                                           Text="Gemini API 키" />
                            </Border>
                            <PasswordBox x:Name="ApiKeyBox"
                                         Grid.Column="1"
                                         AutomationProperties.Name="Gemini API 키"
                                         Style="{StaticResource RoundedPasswordBox}"
                                         VerticalContentAlignment="Center"
                                         LostKeyboardFocus="ApiKeyBox_LostKeyboardFocus" />
                        </Grid>
                    </Border>
                    <CheckBox x:Name="RememberApiKeyCheckBox"
                              Grid.Column="2"
                              Margin="13,0,2,0"
                              VerticalAlignment="Center"
                              Checked="RememberApiKeyCheckBox_Checked"
                              Content="API 키 기억하기"
                              Cursor="Hand"
                              FontSize="12"
                              Foreground="{StaticResource MutedBrush}"
                              Unchecked="RememberApiKeyCheckBox_Unchecked" />
                </Grid>
            </Border>

            <Border Grid.Row="2"
                    Padding="18"
                    Background="{StaticResource CardBrush}"
                    BorderBrush="{StaticResource BorderBrush}"
                    BorderThickness="1"
                    CornerRadius="22">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="18" Opacity="0.08" ShadowDepth="5" Color="#FF655B82" />
                </Border.Effect>
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0"
                            Margin="0,0,0,13"
                            Padding="6"
                            Background="#FFFBFAFE"
                            CornerRadius="17">
                        <ScrollViewer x:Name="ChatScrollViewer"
                                      VerticalScrollBarVisibility="Auto">
                            <ItemsControl x:Name="ChatMessages" ItemsSource="{Binding Messages}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Grid Margin="4,6">
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                            </Grid.RowDefinitions>
                                            <Border x:Name="MessageBubble"
                                                    Grid.Row="0"
                                                    MaxWidth="1300"
                                                    Padding="14,11"
                                                    HorizontalAlignment="Left"
                                                    Background="White"
                                                    BorderBrush="#FFEAE6F2"
                                                    BorderThickness="1"
                                                    CornerRadius="17">
                                                <StackPanel>
                                                    <TextBox x:Name="MessageText"
                                                             Padding="0"
                                                             Background="Transparent"
                                                             BorderThickness="0"
                                                             Cursor="IBeam"
                                                             FontFamily="Segoe UI Variable Text, Malgun Gothic"
                                                             FontSize="15.5"
                                                             IsReadOnly="True"
                                                             IsReadOnlyCaretVisible="False"
                                                             TextBlock.LineHeight="30"
                                                             TextBlock.LineStackingStrategy="BlockLineHeight"
                                                             Foreground="{StaticResource InkBrush}"
                                                             Text="{Binding Text}"
                                                             TextWrapping="Wrap" />
                                                    <StackPanel x:Name="EditMessagePanel" Visibility="Collapsed">
                                                        <TextBox x:Name="EditMessageBox"
                                                                 MinWidth="340"
                                                                 MinHeight="86"
                                                                 MaxHeight="260"
                                                                 AcceptsReturn="True"
                                                                 FontFamily="Segoe UI Variable Text, Malgun Gothic"
                                                                 FontSize="15.5"
                                                                 IsVisibleChanged="EditMessageBox_IsVisibleChanged"
                                                                 Text="{Binding EditText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                                 TextBlock.LineHeight="27"
                                                                 TextBlock.LineStackingStrategy="BlockLineHeight"
                                                                 TextWrapping="Wrap"
                                                                 VerticalScrollBarVisibility="Auto"
                                                                 Style="{StaticResource RoundedTextBox}" />
                                                        <StackPanel Margin="0,10,0,0"
                                                                    HorizontalAlignment="Right"
                                                                    Orientation="Horizontal">
                                                            <Button Height="32"
                                                                    Margin="0,0,7,0"
                                                                    Padding="13,4"
                                                                    Click="CancelEditMessageButton_Click"
                                                                    Content="취소"
                                                                    Style="{StaticResource SoftButton}"
                                                                    Tag="{Binding}" />
                                                            <Button Height="32"
                                                                    Padding="13,4"
                                                                    Click="SaveEditMessageButton_Click"
                                                                    Content="저장 후 다시 생성"
                                                                    Style="{StaticResource PrimaryButton}"
                                                                    Tag="{Binding}" />
                                                        </StackPanel>
                                                    </StackPanel>
                                                    <local:ReadableMarkdownViewer x:Name="MarkdownMessage"
                                                                                  Background="Transparent"
                                                                                  BorderThickness="0"
                                                                                  FontFamily="Segoe UI Variable Text, Malgun Gothic"
                                                                                  FontSize="15.5"
                                                                                  Foreground="{StaticResource InkBrush}"
                                                                                  HorizontalScrollBarVisibility="Disabled"
                                                                                  Markdown="{Binding Text}"
                                                                                  VerticalScrollBarVisibility="Disabled"
                                                                                  Visibility="Collapsed" />

                                                    <ItemsControl ItemsSource="{Binding Attachments}">
                                                        <ItemsControl.Style>
                                                            <Style TargetType="ItemsControl">
                                                                <Setter Property="Margin" Value="0,10,0,0" />
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding Attachments.Count}" Value="0">
                                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </ItemsControl.Style>
                                                        <ItemsControl.ItemTemplate>
                                                            <DataTemplate>
                                                                <Border Margin="0,4,0,0"
                                                                        Padding="10"
                                                                        Background="#FFFCFBFE"
                                                                        BorderBrush="{StaticResource BorderBrush}"
                                                                        BorderThickness="1"
                                                                        CornerRadius="12">
                                                                    <StackPanel>
                                                                        <Image x:Name="AttachmentPreview"
                                                                               MaxWidth="600"
                                                                               MaxHeight="420"
                                                                               Margin="0,0,0,9"
                                                                               HorizontalAlignment="Left"
                                                                               Source="{Binding Path, Converter={StaticResource AttachmentPreviewConverter}}"
                                                                               Stretch="Uniform"
                                                                               Visibility="Collapsed" />
                                                                        <DockPanel LastChildFill="True">
                                                                            <StackPanel DockPanel.Dock="Right" Margin="10,0,0,0" Orientation="Horizontal">
                                                                                <Button Height="30"
                                                                                        Margin="0,0,6,0"
                                                                                        Padding="10,3"
                                                                                        Style="{StaticResource SoftButton}"
                                                                                        Click="OpenAttachmentButton_Click"
                                                                                        Tag="{Binding}"
                                                                                        Content="열기" />
                                                                                <Button Height="30"
                                                                                        Padding="10,3"
                                                                                        Style="{StaticResource SoftButton}"
                                                                                        Click="SaveAttachmentButton_Click"
                                                                                        Tag="{Binding}"
                                                                                        Content="저장" />
                                                                            </StackPanel>
                                                                            <StackPanel VerticalAlignment="Center">
                                                                                <TextBlock FontWeight="SemiBold"
                                                                                           Foreground="{StaticResource InkBrush}"
                                                                                           Text="{Binding Name}"
                                                                                           TextTrimming="CharacterEllipsis" />
                                                                                <TextBlock Margin="0,2,0,0"
                                                                                           FontSize="10"
                                                                                           Foreground="{StaticResource MutedBrush}"
                                                                                           Text="{Binding DisplaySize}" />
                                                                            </StackPanel>
                                                                        </DockPanel>
                                                                    </StackPanel>
                                                                </Border>
                                                                <DataTemplate.Triggers>
                                                                    <DataTrigger Binding="{Binding IsImage}" Value="True">
                                                                        <Setter TargetName="AttachmentPreview" Property="Visibility" Value="Visible" />
                                                                    </DataTrigger>
                                                                </DataTemplate.Triggers>
                                                            </DataTemplate>
                                                        </ItemsControl.ItemTemplate>
                                                    </ItemsControl>

                                                    <ItemsControl ItemsSource="{Binding Sources}">
                                                        <ItemsControl.Style>
                                                            <Style TargetType="ItemsControl">
                                                                <Setter Property="Margin" Value="0,11,0,0" />
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding Sources.Count}" Value="0">
                                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </ItemsControl.Style>
                                                        <ItemsControl.Template>
                                                            <ControlTemplate TargetType="ItemsControl">
                                                                <StackPanel>
                                                                    <Separator Margin="0,0,0,8" Background="{StaticResource BorderBrush}" />
                                                                    <TextBlock Margin="0,0,0,4"
                                                                               FontSize="11"
                                                                               FontWeight="SemiBold"
                                                                               Foreground="{StaticResource MutedBrush}"
                                                                               Text="참고한 출처" />
                                                                    <ItemsPresenter />
                                                                </StackPanel>
                                                            </ControlTemplate>
                                                        </ItemsControl.Template>
                                                        <ItemsControl.ItemTemplate>
                                                            <DataTemplate>
                                                                <TextBlock Margin="0,2,0,0" FontSize="11" TextTrimming="CharacterEllipsis">
                                                                    <Hyperlink NavigateUri="{Binding Uri}"
                                                                               Foreground="{StaticResource PrimaryBrush}"
                                                                               RequestNavigate="SourceLink_RequestNavigate">
                                                                        <Run Text="{Binding Title}" />
                                                                    </Hyperlink>
                                                                </TextBlock>
                                                            </DataTemplate>
                                                        </ItemsControl.ItemTemplate>
                                                    </ItemsControl>
                                                </StackPanel>
                                            </Border>

                                            <StackPanel x:Name="UserActions"
                                                        Grid.Row="1"
                                                        Margin="0,3,10,0"
                                                        HorizontalAlignment="Right"
                                                        Orientation="Horizontal"
                                                        Visibility="Collapsed">
                                                <Button AutomationProperties.Name="내 메시지 복사"
                                                        Click="CopyUserMessageButton_Click"
                                                        Content="&#xE8C8;"
                                                        Style="{StaticResource ResponseActionButton}"
                                                        Tag="{Binding}"
                                                        ToolTip="내 메시지 복사" />
                                                <Button AutomationProperties.Name="내 메시지 편집"
                                                        Click="EditUserMessageButton_Click"
                                                        Content="&#xE70F;"
                                                        Tag="{Binding}"
                                                        ToolTip="내 메시지 편집">
                                                    <Button.Style>
                                                        <Style TargetType="Button" BasedOn="{StaticResource ResponseActionButton}">
                                                            <Setter Property="Visibility" Value="Collapsed" />
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding CanEdit}" Value="True">
                                                                    <Setter Property="Visibility" Value="Visible" />
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Button.Style>
                                                </Button>
                                            </StackPanel>

                                            <StackPanel x:Name="ResponseActions"
                                                        Grid.Row="1"
                                                        Margin="10,3,0,0"
                                                        HorizontalAlignment="Left"
                                                        Orientation="Horizontal"
                                                        Visibility="Collapsed">
                                                <Border x:Name="ResponseModelBadge"
                                                        Height="25"
                                                        Margin="0,1,7,0"
                                                        Padding="8,3"
                                                        VerticalAlignment="Top"
                                                        Background="{StaticResource PrimarySoftBrush}"
                                                        CornerRadius="8"
                                                        ToolTip="{Binding ModelId}">
                                                    <StackPanel Orientation="Horizontal">
                                                        <TextBlock Margin="0,0,4,0"
                                                                   FontSize="10"
                                                                   Foreground="{StaticResource PrimaryBrush}"
                                                                   Text="✦" />
                                                        <TextBlock x:Name="ResponseModelName"
                                                                   FontFamily="Segoe UI Variable Text, Malgun Gothic"
                                                                   FontSize="10"
                                                                   FontWeight="SemiBold"
                                                                   Foreground="#FF5D51C6"
                                                                   Text="{Binding ModelDisplayName}" />
                                                    </StackPanel>
                                                </Border>
                                                <Button AutomationProperties.Name="응답 전체 복사"
                                                        Click="CopyResponseButton_Click"
                                                        Content="&#xE8C8;"
                                                        Style="{StaticResource ResponseActionButton}"
                                                        Tag="{Binding}"
                                                        ToolTip="응답 전체 복사" />
                                                <Button AutomationProperties.Name="답변 다시 생성"
                                                        Click="RegenerateResponseButton_Click"
                                                        Content="&#xE72C;"
                                                        Tag="{Binding}"
                                                        ToolTip="답변 다시 생성">
                                                    <Button.Style>
                                                        <Style TargetType="Button" BasedOn="{StaticResource ResponseActionButton}">
                                                            <Setter Property="Visibility" Value="Collapsed" />
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding CanRegenerate}" Value="True">
                                                                    <Setter Property="Visibility" Value="Visible" />
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Button.Style>
                                                </Button>
                                            </StackPanel>
                                        </Grid>
                                        <DataTemplate.Triggers>
                                            <DataTrigger Binding="{Binding IsUser}" Value="True">
                                                <Setter TargetName="MessageBubble" Property="HorizontalAlignment" Value="Right" />
                                                <Setter TargetName="MessageBubble" Property="Background" Value="{StaticResource PrimaryBrush}" />
                                                <Setter TargetName="MessageBubble" Property="BorderThickness" Value="0" />
                                                <Setter TargetName="MessageText" Property="Foreground" Value="White" />
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding IsUser}" Value="False">
                                                <Setter TargetName="MessageText" Property="Visibility" Value="Collapsed" />
                                                <Setter TargetName="MarkdownMessage" Property="Visibility" Value="Visible" />
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding IsStreaming}" Value="True">
                                                <Setter TargetName="MessageText" Property="Visibility" Value="Visible" />
                                                <Setter TargetName="MarkdownMessage" Property="Visibility" Value="Collapsed" />
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding ModelId}" Value="{x:Null}">
                                                <Setter TargetName="ResponseModelBadge" Property="Visibility" Value="Collapsed" />
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding ModelId}" Value="legacy-unknown">
                                                <Setter TargetName="ResponseModelBadge" Property="Background" Value="Transparent" />
                                                <Setter TargetName="ResponseModelBadge" Property="ToolTip" Value="이 응답은 모델 기록 기능이 생기기 전에 저장됐어요" />
                                                <Setter TargetName="ResponseModelName" Property="Foreground" Value="{StaticResource MutedBrush}" />
                                            </DataTrigger>
                                            <MultiDataTrigger>
                                                <MultiDataTrigger.Conditions>
                                                    <Condition Binding="{Binding IsUser}" Value="True" />
                                                    <Condition Binding="{Binding IsEditing}" Value="False" />
                                                </MultiDataTrigger.Conditions>
                                                <Setter TargetName="UserActions" Property="Visibility" Value="Visible" />
                                            </MultiDataTrigger>
                                            <MultiDataTrigger>
                                                <MultiDataTrigger.Conditions>
                                                    <Condition Binding="{Binding IsUser}" Value="False" />
                                                    <Condition Binding="{Binding IsStreaming}" Value="False" />
                                                </MultiDataTrigger.Conditions>
                                                <Setter TargetName="ResponseActions" Property="Visibility" Value="Visible" />
                                            </MultiDataTrigger>
                                            <DataTrigger Binding="{Binding IsEditing}" Value="True">
                                                <Setter TargetName="MessageBubble" Property="HorizontalAlignment" Value="Right" />
                                                <Setter TargetName="MessageBubble" Property="Background" Value="#FFF5F3FF" />
                                                <Setter TargetName="MessageBubble" Property="BorderBrush" Value="{StaticResource PrimaryBrush}" />
                                                <Setter TargetName="MessageBubble" Property="BorderThickness" Value="1" />
                                                <Setter TargetName="MessageText" Property="Visibility" Value="Collapsed" />
                                                <Setter TargetName="EditMessagePanel" Property="Visibility" Value="Visible" />
                                                <Setter TargetName="UserActions" Property="Visibility" Value="Collapsed" />
                                            </DataTrigger>
                                        </DataTemplate.Triggers>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </Border>

                    <DockPanel Grid.Row="1" Margin="1,0,1,10" LastChildFill="True">
                        <StackPanel DockPanel.Dock="Left" Orientation="Horizontal">
                            <Button x:Name="AttachButton"
                                    Height="34"
                                    Padding="12,4"
                                    Style="{StaticResource SoftButton}"
                                    Click="AttachButton_Click"
                                    Content="📎  파일 첨부" />
                            <Button x:Name="ClearAttachmentsButton"
                                    Height="34"
                                    Margin="7,0,0,0"
                                    Padding="12,4"
                                    Style="{StaticResource PillButton}"
                                    Click="ClearAttachmentsButton_Click"
                                    IsEnabled="False"
                                    Content="첨부 비우기" />
                        </StackPanel>
                        <TextBlock x:Name="AttachmentSummaryText"
                                   Margin="12,0,0,0"
                                   VerticalAlignment="Center"
                                   Foreground="{StaticResource MutedBrush}"
                                   Text="첨부 없음"
                                   TextTrimming="CharacterEllipsis" />
                    </DockPanel>

                    <TextBox x:Name="PromptBox"
                             Grid.Row="2"
                             MinHeight="88"
                             MaxHeight="160"
                             Style="{StaticResource RoundedTextBox}"
                             AcceptsReturn="True"
                             FontFamily="Segoe UI Variable Text, Malgun Gothic"
                             FontSize="15"
                             PreviewKeyDown="PromptBox_PreviewKeyDown"
                             TextBlock.LineHeight="26"
                             TextBlock.LineStackingStrategy="BlockLineHeight"
                             TextWrapping="Wrap"
                             VerticalScrollBarVisibility="Auto" />

                    <DockPanel Grid.Row="3" Margin="2,12,2,0" LastChildFill="False">
                        <StackPanel DockPanel.Dock="Left" Orientation="Horizontal" VerticalAlignment="Center">
                            <Border Padding="9,5" Background="#FFF4F2F7" CornerRadius="9">
                                <TextBlock x:Name="StatusText"
                                           FontSize="11"
                                           Foreground="{StaticResource MutedBrush}"
                                           Text="준비됨" />
                            </Border>
                            <CheckBox x:Name="WebSearchCheckBox"
                                      Margin="14,0,0,0"
                                      VerticalAlignment="Center"
                                      IsChecked="True"
                                      Foreground="{StaticResource InkBrush}"
                                      Content="검색을 허용해요!" />
                            <TextBlock Margin="13,0,0,0"
                                       VerticalAlignment="Center"
                                       FontSize="10"
                                       Foreground="#FFA39EAD"
                                       Text="Enter 전송 · Shift+Enter 줄바꿈" />
                        </StackPanel>
                        <Button x:Name="SendButton"
                                DockPanel.Dock="Right"
                                Width="108"
                                Height="41"
                                Style="{StaticResource PrimaryButton}"
                                Click="SendButton_Click"
                                Content="보내기  ↗" />
                    </DockPanel>
                </Grid>
            </Border>

            <TextBlock Grid.Row="3"
                       Margin="0,10,2,0"
                       HorizontalAlignment="Right"
                       FontSize="10"
                       Foreground="#FFA39EAD"
                       Text="대화는 이 PC에만 조용히 저장돼요" />
        </Grid>
    </Grid>
</Window>
