<Window x:Class="GeminiDesk.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:GeminiDesk"
        xmlns:mdxaml="clr-namespace:MdXaml;assembly=MdXaml"
        Title="Bunny Desk"
        Width="1180"
        Height="760"
        MinWidth="900"
        MinHeight="620"
        WindowStartupLocation="CenterScreen"
        FontFamily="Segoe UI Variable Text, Malgun Gothic"
        Background="#FFF8F7FC">
    <Window.Resources>
        <local:AttachmentPreviewConverter x:Key="AttachmentPreviewConverter" />

        <SolidColorBrush x:Key="InkBrush" Color="#FF29263B" />
        <SolidColorBrush x:Key="MutedBrush" Color="#FF797487" />
        <SolidColorBrush x:Key="PrimaryBrush" Color="#FF7567E8" />
        <SolidColorBrush x:Key="PrimarySoftBrush" Color="#FFEDEAFF" />
        <SolidColorBrush x:Key="PinkSoftBrush" Color="#FFFFEAF2" />
        <SolidColorBrush x:Key="BorderBrush" Color="#FFE9E5F1" />
        <SolidColorBrush x:Key="CardBrush" Color="#FFFFFFFF" />

        <Style x:Key="SlimScrollBar" TargetType="ScrollBar">
            <Setter Property="Width" Value="8" />
            <Setter Property="MinWidth" Value="8" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollBar">
                        <Grid Width="8" Background="Transparent">
                            <Track x:Name="PART_Track"
                                   Focusable="False"
                                   IsDirectionReversed="True"
                                   Orientation="Vertical">
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton Command="{x:Static ScrollBar.PageUpCommand}"
                                                  Focusable="False"
                                                  Opacity="0" />
                                </Track.DecreaseRepeatButton>
                                <Track.Thumb>
                                    <Thumb MinHeight="28"
                                           Margin="1,0"
                                           Cursor="Hand">
                                        <Thumb.Template>
                                            <ControlTemplate TargetType="Thumb">
                                                <Border x:Name="ThumbBody"
                                                        Background="#707567E8"
                                                        CornerRadius="3" />
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="ThumbBody"
                                                                Property="Background"
                                                                Value="#B07567E8" />
                                                    </Trigger>
                                                    <Trigger Property="IsDragging" Value="True">
                                                        <Setter TargetName="ThumbBody"
                                                                Property="Background"
                                                                Value="#DD7567E8" />
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Thumb.Template>
                                    </Thumb>
                                </Track.Thumb>
                                <Track.IncreaseRepeatButton>
                                    <RepeatButton Command="{x:Static ScrollBar.PageDownCommand}"
                                                  Focusable="False"
                                                  Opacity="0" />
                                </Track.IncreaseRepeatButton>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="{x:Type Paragraph}">
            <Setter Property="FontFamily" Value="Segoe UI Variable Text, Malgun Gothic" />
            <Setter Property="FontSize" Value="15" />
            <Setter Property="LineHeight" Value="30" />
            <Setter Property="Margin" Value="0,3,0,15" />
        </Style>

        <Style TargetType="{x:Type ListItem}">
            <Setter Property="Margin" Value="0,2,0,5" />
        </Style>

        <Style x:Key="PillButton" TargetType="Button">
            <Setter Property="Height" Value="38" />
            <Setter Property="Padding" Value="15,7" />
            <Setter Property="Background" Value="White" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Foreground" Value="{StaticResource InkBrush}" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="ButtonBorder"
                                Padding="{TemplateBinding Padding}"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="13">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Opacity" Value="0.84" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Opacity" Value="0.68" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="ButtonBorder" Property="Opacity" Value="0.42" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PrimaryButton" TargetType="Button" BasedOn="{StaticResource PillButton}">
            <Setter Property="Background" Value="{StaticResource PrimaryBrush}" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Foreground" Value="White" />
        </Style>

        <Style x:Key="SoftButton" TargetType="Button" BasedOn="{StaticResource PillButton}">
            <Setter Property="Background" Value="{StaticResource PrimarySoftBrush}" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Foreground" Value="#FF5D51C6" />
        </Style>

        <Style x:Key="ResponseActionButton" TargetType="Button">
            <Setter Property="Width" Value="30" />
            <Setter Property="Height" Value="28" />
            <Setter Property="Margin" Value="0,0,3,0" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Foreground" Value="{StaticResource MutedBrush}" />
            <Setter Property="FontFamily" Value="Segoe Fluent Icons, Segoe MDL2 Assets" />
            <Setter Property="FontSize" Value="15" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="ToolTipService.InitialShowDelay" Value="300" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="ActionButtonBorder"
                                Background="{TemplateBinding Background}"
                                CornerRadius="9">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ActionButtonBorder" Property="Background" Value="{StaticResource PrimarySoftBrush}" />
                                <Setter Property="Foreground" Value="{StaticResource PrimaryBrush}" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="ActionButtonBorder" Property="Opacity" Value="0.65" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.35" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ModelPickerButton" TargetType="Button" BasedOn="{StaticResource SoftButton}">
            <Setter Property="Height" Value="40" />
            <Setter Property="Padding" Value="12,6" />
            <Setter Property="Background" Value="{StaticResource PrimarySoftBrush}" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Foreground" Value="#FF5D51C6" />
            <Setter Property="ToolTipService.InitialShowDelay" Value="250" />
        </Style>

        <Style x:Key="DangerButton" TargetType="Button" BasedOn="{StaticResource PillButton}">
            <Setter Property="Background" Value="#FFFFF1F3" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Foreground" Value="#FFC0475D" />
        </Style>

        <Style x:Key="RoundedTextBox" TargetType="TextBox">
            <Setter Property="Padding" Value="13,10" />
            <Setter Property="Background" Value="#FFFCFBFE" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Foreground" Value="{StaticResource InkBrush}" />
            <Setter Property="CaretBrush" Value="{StaticResource PrimaryBrush}" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border x:Name="InputBorder"
                                Padding="{TemplateBinding Padding}"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="14">
                            <ScrollViewer x:Name="PART_ContentHost" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsKeyboardFocused" Value="True">
                                <Setter TargetName="InputBorder" Property="BorderBrush" Value="{StaticResource PrimaryBrush}" />
                                <Setter TargetName="InputBorder" Property="Background" Value="White" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="InputBorder" Property="Opacity" Value="0.55" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="RoundedPasswordBox" TargetType="PasswordBox">
            <Setter Property="Padding" Value="13,8" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Foreground" Value="{StaticResource InkBrush}" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="258" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0"
                Margin="16,16,0,16"
                CornerRadius="25">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Offset="0" Color="#FFF0EDFF" />
                    <GradientStop Offset="0.55" Color="#FFFFF2F7" />
                    <GradientStop Offset="1" Color="#FFEDF7FF" />
                </LinearGradientBrush>
            </Border.Background>
            <Border.Effect>
                <DropShadowEffect BlurRadius="20" Opacity="0.10" ShadowDepth="5" Color="#FF655B82" />
            </Border.Effect>
            <Grid Margin="18">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <StackPanel Orientation="Horizontal" Margin="2,4,0,20">
                    <Border Width="42" Height="42" Background="{StaticResource PrimaryBrush}" CornerRadius="15">
                        <TextBlock HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   FontSize="21"
                                   Foreground="White"
                                   Text="🐇" />
                    </Border>
                    <StackPanel Margin="11,1,0,0">
                        <TextBlock FontSize="19"
                                   FontWeight="Bold"
                                   Foreground="{StaticResource InkBrush}"
                                   Text="Bunny Desk" />
                        <TextBlock Margin="0,2,0,0"
                                   FontSize="11"
                                   Foreground="{StaticResource MutedBrush}"
                                   Text="여러 AI를 가볍게 폴짝" />
                    </StackPanel>
                </StackPanel>

                <Button x:Name="NewChatButton"
                        Grid.Row="1"
                        Height="43"
                        Style="{StaticResource PrimaryButton}"
                        Click="NewChatButton_Click"
                        Content="＋  새 대화" />

                <Button x:Name="ApiKeySettingsButton"
                        Grid.Row="2"
                        Height="40"
                        Margin="0,8,0,0"
                        Style="{StaticResource SoftButton}"
                        Click="ApiKeySettingsButton_Click"
                        Content="🔑  API 키 설정" />

                <Button x:Name="UsageButton"
                        Grid.Row="3"
                        Height="40"
                        Margin="0,7,0,0"
                        Style="{StaticResource PillButton}"
                        Click="UsageButton_Click"
                        Content="₩  사용료" />

                <DockPanel Grid.Row="4" Margin="4,22,4,8">
                    <TextBlock FontSize="12"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource MutedBrush}"
                               Text="최근 대화" />
                </DockPanel>

                <ListBox x:Name="ConversationList"
                         Grid.Row="5"
                         ItemsSource="{Binding Conversations}"
                         Background="Transparent"
                         BorderThickness="0"
                         PreviewMouseWheel="ConversationList_PreviewMouseWheel"
                         PreviewMouseRightButtonDown="ConversationList_PreviewMouseRightButtonDown"
                         SelectionChanged="ConversationList_SelectionChanged"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                         ScrollViewer.VerticalScrollBarVisibility="Auto"
                         ScrollViewer.ScrollChanged="ConversationList_ScrollChanged"
                         VirtualizingPanel.IsVirtualizing="True"
                         VirtualizingPanel.VirtualizationMode="Recycling">
                    <ListBox.Resources>
                        <Style TargetType="ScrollBar" BasedOn="{StaticResource SlimScrollBar}" />
                    </ListBox.Resources>
                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem">
                            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                            <Setter Property="Padding" Value="0" />
                            <Setter Property="Margin" Value="0,2" />
                            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="ListBoxItem">
                                        <Border x:Name="HistoryItem"
                                                Padding="11,9"
                                                Background="Transparent"
                                                CornerRadius="13">
                                            <ContentPresenter />
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="HistoryItem" Property="Background" Value="#99FFFFFF" />
                                            </Trigger>
                                            <Trigger Property="IsSelected" Value="True">
                                                <Setter TargetName="HistoryItem" Property="Background" Value="White" />
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </ListBox.ItemContainerStyle>
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <StackPanel>
                                <TextBlock FontWeight="SemiBold"
                                           Foreground="{StaticResource InkBrush}"
                                           Text="{Binding Title}"
                                           TextTrimming="CharacterEllipsis" />
                                <TextBlock Margin="0,3,0,0"
                                           FontSize="10"
                                           Foreground="{StaticResource MutedBrush}"
                                           Text="{Binding UpdatedLabel}" />
                            </StackPanel>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>

                <StackPanel Grid.Row="6" Margin="2,10,2,0">
                    <DockPanel LastChildFill="False">
                        <TextBlock x:Name="VersionText"
                                   VerticalAlignment="Center"
                                   FontSize="10"
                                   Foreground="{StaticResource MutedBrush}"
                                   Text="v0.1.0" />
                        <Button x:Name="UpdateButton"
                                DockPanel.Dock="Right"
                                Height="28"
                                Padding="10,2"
                                AutomationProperties.Name="Bunny Desk 업데이트 확인"
                                Click="UpdateButton_Click"
                                Content="업데이트 확인"
                                FontSize="10"
                                Style="{StaticResource SoftButton}" />
                        <Button x:Name="ManualButton"
                                DockPanel.Dock="Right"
                                Width="28"
                                Height="28"
                                Margin="0,0,6,0"
                                Padding="0"
                                AutomationProperties.Name="Bunny Desk 사용법"
                                Click="ManualButton_Click"
                                Content="?"
                                FontSize="13"
                                FontWeight="Bold"
                                Style="{StaticResource SoftButton}"
                                ToolTip="Bunny Desk 사용법" />
                    </DockPanel>
                    <TextBlock x:Name="UpdateDetailText"
                               Margin="0,5,0,0"
                               FontSize="9.5"
                               Foreground="{StaticResource MutedBrush}"
                               TextWrapping="Wrap"
                               Visibility="Collapsed" />
                </StackPanel>
            </Grid>
        </Border>

        <Grid x:Name="ChatView" Grid.Column="1" Margin="28,22,28,18">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <DockPanel Grid.Row="0" Margin="2,0,2,18">
                <StackPanel x:Name="ModelSelector"
                            DockPanel.Dock="Right"
                            Margin="18,0,0,0"
                            VerticalAlignment="Center">
                    <TextBlock Margin="5,0,0,4"
                               FontSize="10"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource MutedBrush}"
                               Text="사용할 모델" />
                    <Button x:Name="ModelMenuButton"
                            AutomationProperties.Name="사용할 AI 모델 선택"
                            Click="ModelMenuButton_Click"
                            Style="{StaticResource ModelPickerButton}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock x:Name="SelectedModelIcon"
                                       Margin="0,0,6,0"
                                       VerticalAlignment="Center"
                                       FontSize="12"
                                       Text="⚡" />
                            <TextBlock x:Name="SelectedModelName"
                                       VerticalAlignment="Center"
                                       FontFamily="Segoe UI Variable Text, Malgun Gothic"
                                       FontSize="12"
                                       FontWeight="SemiBold"
                                       Text="3.5 Flash" />
                            <Border x:Name="SelectedModelBadge"
                                    Margin="7,0,0,0"
                                    Padding="5,1"
                                    VerticalAlignment="Center"
                                    Background="#FFFFEDF4"
                                    CornerRadius="6"
                                    Visibility="Collapsed">
                                <TextBlock x:Name="SelectedModelBadgeText"
                                           FontSize="8"
                                           FontWeight="Bold"
                                           Foreground="#FFB04C75" />
                            </Border>
                            <TextBlock Margin="8,-2,0,0"
                                       VerticalAlignment="Center"
                                       FontSize="13"
                                       Foreground="{StaticResource MutedBrush}"
                                       Text="⌄" />
                        </StackPanel>
                    </Button>
                </StackPanel>
                <StackPanel>
                    <TextBlock FontSize="27"
                               FontWeight="Bold"
                               Foreground="{StaticResource InkBrush}"
                               Text="오늘은 무엇을 이야기할까요?" />
                    <TextBlock Margin="1,6,0,0"
                               Foreground="{StaticResource MutedBrush}"
                               Text="궁금한 것, 만들고 싶은 것, 아무 이야기나 편하게 꺼내보세요 ✨" />
                </StackPanel>
            </DockPanel>

            <Border Grid.Row="1"
                    Padding="18"
                    Background="{StaticResource CardBrush}"
                    BorderBrush="{StaticResource BorderBrush}"
                    BorderThickness="1"
                    CornerRadius="22">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="18" Opacity="0.08" ShadowDepth="5" Color="#FF655B82" />
                </Border.Effect>
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0"
                            Margin="0,0,0,13"
                            Padding="6"
                            Background="#FFFBFAFE"
                            CornerRadius="17">
                        <ScrollViewer x:Name="ChatScrollViewer"
                                      VerticalScrollBarVisibility="Auto">
                            <ScrollViewer.Resources>
                                <Style TargetType="ScrollBar" BasedOn="{StaticResource SlimScrollBar}" />
                            </ScrollViewer.Resources>
                            <ItemsControl x:Name="ChatMessages" ItemsSource="{Binding Messages}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Grid Margin="4,6">
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                            </Grid.RowDefinitions>
                                            <Border x:Name="MessageBubble"
                                                    Grid.Row="0"
                                                    MaxWidth="1300"
                                                    Padding="14,11"
                                                    HorizontalAlignment="Left"
                                                    Background="White"
                                                    BorderBrush="#FFEAE6F2"
                                                    BorderThickness="1"
                                                    CornerRadius="17">
                                                <StackPanel>
                                                    <StackPanel x:Name="WaitingPanel"
                                                                MinWidth="240"
                                                                AutomationProperties.Name="AI 답변 준비 중"
                                                                Visibility="Collapsed">
                                                        <TextBlock FontFamily="Segoe UI Variable Text, Malgun Gothic"
                                                                   FontSize="13"
                                                                   FontWeight="SemiBold"
                                                                   Foreground="#FF655AA8"
                                                                   Text="답변 준비 중이에요…" />
                                                        <ProgressBar Height="5"
                                                                     Margin="0,10,0,2"
                                                                     Background="{StaticResource PrimarySoftBrush}"
                                                                     BorderThickness="0"
                                                                     Foreground="{StaticResource PrimaryBrush}"
                                                                     IsIndeterminate="True" />
                                                    </StackPanel>
                                                    <TextBox x:Name="MessageText"
                                                             Padding="0"
                                                             Background="Transparent"
                                                             BorderThickness="0"
                                                             Cursor="IBeam"
                                                             FontFamily="Segoe UI Variable Text, Malgun Gothic"
                                                             FontSize="15.5"
                                                             IsReadOnly="True"
                                                             IsReadOnlyCaretVisible="False"
                                                             TextBlock.LineHeight="30"
                                                             TextBlock.LineStackingStrategy="BlockLineHeight"
                                                             Foreground="{StaticResource InkBrush}"
                                                             Text="{Binding Text}"
                                                             TextWrapping="Wrap" />
                                                    <StackPanel x:Name="EditMessagePanel" Visibility="Collapsed">
                                                        <TextBox x:Name="EditMessageBox"
                                                                 MinWidth="340"
                                                                 MinHeight="86"
                                                                 MaxHeight="260"
                                                                 AcceptsReturn="True"
                                                                 FontFamily="Segoe UI Variable Text, Malgun Gothic"
                                                                 FontSize="15.5"
                                                                 IsVisibleChanged="EditMessageBox_IsVisibleChanged"
                                                                 Text="{Binding EditText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                                 TextBlock.LineHeight="27"
                                                                 TextBlock.LineStackingStrategy="BlockLineHeight"
                                                                 TextWrapping="Wrap"
                                                                 VerticalScrollBarVisibility="Auto"
                                                                 Style="{StaticResource RoundedTextBox}" />
                                                        <StackPanel Margin="0,10,0,0"
                                                                    HorizontalAlignment="Right"
                                                                    Orientation="Horizontal">
                                                            <Button Height="32"
                                                                    Margin="0,0,7,0"
                                                                    Padding="13,4"
                                                                    Click="CancelEditMessageButton_Click"
                                                                    Content="취소"
                                                                    Style="{StaticResource SoftButton}"
                                                                    Tag="{Binding}" />
                                                            <Button Height="32"
                                                                    Padding="13,4"
                                                                    Click="SaveEditMessageButton_Click"
                                                                    Content="저장 후 다시 생성"
                                                                    Style="{StaticResource PrimaryButton}"
                                                                    Tag="{Binding}" />
                                                        </StackPanel>
                                                    </StackPanel>
                                                    <local:ReadableMarkdownViewer x:Name="MarkdownMessage"
                                                                                  Background="Transparent"
                                                                                  BorderThickness="0"
                                                                                  FontFamily="Segoe UI Variable Text, Malgun Gothic"
                                                                                  FontSize="15.5"
                                                                                  Foreground="{StaticResource InkBrush}"
                                                                                  HorizontalScrollBarVisibility="Disabled"
                                                                                  Markdown="{Binding Text}"
                                                                                  VerticalScrollBarVisibility="Disabled"
                                                                                  Visibility="Collapsed" />

                                                    <ItemsControl ItemsSource="{Binding Attachments}">
                                                        <ItemsControl.Style>
                                                            <Style TargetType="ItemsControl">
                                                                <Setter Property="Margin" Value="0,10,0,0" />
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding Attachments.Count}" Value="0">
                                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </ItemsControl.Style>
                                                        <ItemsControl.ItemTemplate>
                                                            <DataTemplate>
                                                                <Border Margin="0,4,0,0"
                                                                        Padding="10"
                                                                        Background="#FFFCFBFE"
                                                                        BorderBrush="{StaticResource BorderBrush}"
                                                                        BorderThickness="1"
                                                                        CornerRadius="12">
                                                                    <StackPanel>
                                                                        <Image x:Name="AttachmentPreview"
                                                                               MaxWidth="600"
                                                                               MaxHeight="420"
                                                                               Margin="0,0,0,9"
                                                                               HorizontalAlignment="Left"
                                                                               Source="{Binding Path, Converter={StaticResource AttachmentPreviewConverter}}"
                                                                               Stretch="Uniform"
                                                                               Visibility="Collapsed" />
                                                                        <DockPanel LastChildFill="True">
                                                                            <StackPanel DockPanel.Dock="Right" Margin="10,0,0,0" Orientation="Horizontal">
                                                                                <Button Height="30"
                                                                                        Margin="0,0,6,0"
                                                                                        Padding="10,3"
                                                                                        Style="{StaticResource SoftButton}"
                                                                                        Click="OpenAttachmentButton_Click"
                                                                                        Tag="{Binding}"
                                                                                        Content="열기" />
                                                                                <Button Height="30"
                                                                                        Padding="10,3"
                                                                                        Style="{StaticResource SoftButton}"
                                                                                        Click="SaveAttachmentButton_Click"
                                                                                        Tag="{Binding}"
                                                                                        Content="저장" />
                                                                            </StackPanel>
                                                                            <StackPanel VerticalAlignment="Center">
                                                                                <TextBlock FontWeight="SemiBold"
                                                                                           Foreground="{StaticResource InkBrush}"
                                                                                           Text="{Binding Name}"
                                                                                           TextTrimming="CharacterEllipsis" />
                                                                                <TextBlock Margin="0,2,0,0"
                                                                                           FontSize="10"
                                                                                           Foreground="{StaticResource MutedBrush}"
                                                                                           Text="{Binding DisplaySize}" />
                                                                            </StackPanel>
                                                                        </DockPanel>
                                                                    </StackPanel>
                                                                </Border>
                                                                <DataTemplate.Triggers>
                                                                    <DataTrigger Binding="{Binding IsImage}" Value="True">
                                                                        <Setter TargetName="AttachmentPreview" Property="Visibility" Value="Visible" />
                                                                    </DataTrigger>
                                                                </DataTemplate.Triggers>
                                                            </DataTemplate>
                                                        </ItemsControl.ItemTemplate>
                                                    </ItemsControl>

                                                    <ItemsControl ItemsSource="{Binding Sources}">
                                                        <ItemsControl.Style>
                                                            <Style TargetType="ItemsControl">
                                                                <Setter Property="Margin" Value="0,11,0,0" />
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding Sources.Count}" Value="0">
                                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </ItemsControl.Style>
                                                        <ItemsControl.Template>
                                                            <ControlTemplate TargetType="ItemsControl">
                                                                <StackPanel>
                                                                    <Separator Margin="0,0,0,8" Background="{StaticResource BorderBrush}" />
                                                                    <TextBlock Margin="0,0,0,4"
                                                                               FontSize="11"
                                                                               FontWeight="SemiBold"
                                                                               Foreground="{StaticResource MutedBrush}"
                                                                               Text="참고한 출처" />
                                                                    <ItemsPresenter />
                                                                </StackPanel>
                                                            </ControlTemplate>
                                                        </ItemsControl.Template>
                                                        <ItemsControl.ItemTemplate>
                                                            <DataTemplate>
                                                                <TextBlock Margin="0,2,0,0" FontSize="11" TextTrimming="CharacterEllipsis">
                                                                    <Hyperlink NavigateUri="{Binding Uri}"
                                                                               Foreground="{StaticResource PrimaryBrush}"
                                                                               RequestNavigate="SourceLink_RequestNavigate">
                                                                        <Run Text="{Binding Title}" />
                                                                    </Hyperlink>
                                                                </TextBlock>
                                                            </DataTemplate>
                                                        </ItemsControl.ItemTemplate>
                                                    </ItemsControl>
                                                </StackPanel>
                                            </Border>

                                            <StackPanel x:Name="UserActions"
                                                        Grid.Row="1"
                                                        Margin="0,3,10,0"
                                                        HorizontalAlignment="Right"
                                                        Orientation="Horizontal"
                                                        Visibility="Collapsed">
                                                <Button AutomationProperties.Name="내 메시지 복사"
                                                        Click="CopyUserMessageButton_Click"
                                                        Content="&#xE8C8;"
                                                        Style="{StaticResource ResponseActionButton}"
                                                        Tag="{Binding}"
                                                        ToolTip="내 메시지 복사" />
                                                <Button AutomationProperties.Name="내 메시지 편집"
                                                        Click="EditUserMessageButton_Click"
                                                        Content="&#xE70F;"
                                                        Tag="{Binding}"
                                                        ToolTip="내 메시지 편집">
                                                    <Button.Style>
                                                        <Style TargetType="Button" BasedOn="{StaticResource ResponseActionButton}">
                                                            <Setter Property="Visibility" Value="Collapsed" />
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding CanEdit}" Value="True">
                                                                    <Setter Property="Visibility" Value="Visible" />
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Button.Style>
                                                </Button>
                                            </StackPanel>

                                            <StackPanel x:Name="ResponseActions"
                                                        Grid.Row="1"
                                                        Margin="10,3,0,0"
                                                        HorizontalAlignment="Left"
                                                        Orientation="Horizontal"
                                                        Visibility="Collapsed">
                                                <Border x:Name="ResponseModelBadge"
                                                        Height="25"
                                                        Margin="0,1,7,0"
                                                        Padding="8,3"
                                                        VerticalAlignment="Top"
                                                        Background="{StaticResource PrimarySoftBrush}"
                                                        CornerRadius="8"
                                                        ToolTip="{Binding ModelId}">
                                                    <StackPanel Orientation="Horizontal">
                                                        <TextBlock Margin="0,0,4,0"
                                                                   FontSize="10"
                                                                   Foreground="{StaticResource PrimaryBrush}"
                                                                   Text="✦" />
                                                        <TextBlock x:Name="ResponseModelName"
                                                                   FontFamily="Segoe UI Variable Text, Malgun Gothic"
                                                                   FontSize="10"
                                                                   FontWeight="SemiBold"
                                                                   Foreground="#FF5D51C6"
                                                                   Text="{Binding ModelDisplayName}" />
                                                    </StackPanel>
                                                </Border>
                                                <Button AutomationProperties.Name="응답 전체 복사"
                                                        Click="CopyResponseButton_Click"
                                                        Content="&#xE8C8;"
                                                        Style="{StaticResource ResponseActionButton}"
                                                        Tag="{Binding}"
                                                        ToolTip="응답 전체 복사" />
                                                <Button AutomationProperties.Name="답변 다시 생성"
                                                        Click="RegenerateResponseButton_Click"
                                                        Content="&#xE72C;"
                                                        Tag="{Binding}"
                                                        ToolTip="답변 다시 생성">
                                                    <Button.Style>
                                                        <Style TargetType="Button" BasedOn="{StaticResource ResponseActionButton}">
                                                            <Setter Property="Visibility" Value="Collapsed" />
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding CanRegenerate}" Value="True">
                                                                    <Setter Property="Visibility" Value="Visible" />
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Button.Style>
                                                </Button>
                                            </StackPanel>
                                        </Grid>
                                        <DataTemplate.Triggers>
                                            <DataTrigger Binding="{Binding IsUser}" Value="True">
                                                <Setter TargetName="MessageBubble" Property="HorizontalAlignment" Value="Right" />
                                                <Setter TargetName="MessageBubble" Property="Background" Value="{StaticResource PrimaryBrush}" />
                                                <Setter TargetName="MessageBubble" Property="BorderThickness" Value="0" />
                                                <Setter TargetName="MessageText" Property="Foreground" Value="White" />
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding IsUser}" Value="False">
                                                <Setter TargetName="MessageText" Property="Visibility" Value="Collapsed" />
                                                <Setter TargetName="MarkdownMessage" Property="Visibility" Value="Visible" />
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding IsStreaming}" Value="True">
                                                <Setter TargetName="MessageText" Property="Visibility" Value="Visible" />
                                                <Setter TargetName="MarkdownMessage" Property="Visibility" Value="Collapsed" />
                                            </DataTrigger>
                                            <MultiDataTrigger>
                                                <MultiDataTrigger.Conditions>
                                                    <Condition Binding="{Binding IsUser}" Value="False" />
                                                    <Condition Binding="{Binding IsStreaming}" Value="True" />
                                                    <Condition Binding="{Binding Text}" Value="" />
                                                </MultiDataTrigger.Conditions>
                                                <Setter TargetName="WaitingPanel" Property="Visibility" Value="Visible" />
                                                <Setter TargetName="MessageText" Property="Visibility" Value="Collapsed" />
                                            </MultiDataTrigger>
                                            <DataTrigger Binding="{Binding ModelId}" Value="{x:Null}">
                                                <Setter TargetName="ResponseModelBadge" Property="Visibility" Value="Collapsed" />
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding ModelId}" Value="legacy-unknown">
                                                <Setter TargetName="ResponseModelBadge" Property="Background" Value="Transparent" />
                                                <Setter TargetName="ResponseModelBadge" Property="ToolTip" Value="이 응답은 모델 기록 기능이 생기기 전에 저장됐어요" />
                                                <Setter TargetName="ResponseModelName" Property="Foreground" Value="{StaticResource MutedBrush}" />
                                            </DataTrigger>
                                            <MultiDataTrigger>
                                                <MultiDataTrigger.Conditions>
                                                    <Condition Binding="{Binding IsUser}" Value="True" />
                                                    <Condition Binding="{Binding IsEditing}" Value="False" />
                                                </MultiDataTrigger.Conditions>
                                                <Setter TargetName="UserActions" Property="Visibility" Value="Visible" />
                                            </MultiDataTrigger>
                                            <MultiDataTrigger>
                                                <MultiDataTrigger.Conditions>
                                                    <Condition Binding="{Binding IsUser}" Value="False" />
                                                    <Condition Binding="{Binding IsStreaming}" Value="False" />
                                                </MultiDataTrigger.Conditions>
                                                <Setter TargetName="ResponseActions" Property="Visibility" Value="Visible" />
                                            </MultiDataTrigger>
                                            <DataTrigger Binding="{Binding IsEditing}" Value="True">
                                                <Setter TargetName="MessageBubble" Property="HorizontalAlignment" Value="Right" />
                                                <Setter TargetName="MessageBubble" Property="Background" Value="#FFF5F3FF" />
                                                <Setter TargetName="MessageBubble" Property="BorderBrush" Value="{StaticResource PrimaryBrush}" />
                                                <Setter TargetName="MessageBubble" Property="BorderThickness" Value="1" />
                                                <Setter TargetName="MessageText" Property="Visibility" Value="Collapsed" />
                                                <Setter TargetName="EditMessagePanel" Property="Visibility" Value="Visible" />
                                                <Setter TargetName="UserActions" Property="Visibility" Value="Collapsed" />
                                            </DataTrigger>
                                        </DataTemplate.Triggers>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </Border>

                    <DockPanel Grid.Row="1" Margin="1,0,1,10" LastChildFill="True">
                        <StackPanel DockPanel.Dock="Left" Orientation="Horizontal">
                            <Button x:Name="AttachButton"
                                    Height="34"
                                    Padding="12,4"
                                    Style="{StaticResource SoftButton}"
                                    Click="AttachButton_Click"
                                    Content="📎  파일 첨부" />
                            <Button x:Name="ClearAttachmentsButton"
                                    Height="34"
                                    Margin="7,0,0,0"
                                    Padding="12,4"
                                    Style="{StaticResource PillButton}"
                                    Click="ClearAttachmentsButton_Click"
                                    IsEnabled="False"
                                    Content="첨부 비우기" />
                        </StackPanel>
                        <TextBlock x:Name="AttachmentSummaryText"
                                   Margin="12,0,0,0"
                                   VerticalAlignment="Center"
                                   Foreground="{StaticResource MutedBrush}"
                                   Text="첨부 없음"
                                   TextTrimming="CharacterEllipsis" />
                    </DockPanel>

                    <TextBox x:Name="PromptBox"
                             Grid.Row="2"
                             MinHeight="88"
                             MaxHeight="160"
                             Style="{StaticResource RoundedTextBox}"
                             AcceptsReturn="True"
                             FontFamily="Segoe UI Variable Text, Malgun Gothic"
                             FontSize="15"
                             PreviewKeyDown="PromptBox_PreviewKeyDown"
                             TextBlock.LineHeight="26"
                             TextBlock.LineStackingStrategy="BlockLineHeight"
                             TextWrapping="Wrap"
                             VerticalScrollBarVisibility="Auto" />

                    <DockPanel Grid.Row="3" Margin="2,12,2,0" LastChildFill="False">
                        <StackPanel DockPanel.Dock="Left" Orientation="Horizontal" VerticalAlignment="Center">
                            <Border Padding="9,5" Background="#FFF4F2F7" CornerRadius="9">
                                <TextBlock x:Name="StatusText"
                                           FontSize="11"
                                           Foreground="{StaticResource MutedBrush}"
                                           Text="준비됨" />
                            </Border>
                            <CheckBox x:Name="WebSearchCheckBox"
                                      Margin="14,0,0,0"
                                      VerticalAlignment="Center"
                                      IsChecked="True"
                                      Foreground="{StaticResource InkBrush}"
                                      Content="검색을 허용해요!" />
                            <TextBlock x:Name="WebSearchUnavailableText"
                                       Margin="14,0,0,0"
                                       VerticalAlignment="Center"
                                       FontSize="12"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource MutedBrush}"
                                       Text="이 모델은 웹 검색을 못해요!"
                                       Visibility="Collapsed" />
                            <TextBlock Margin="13,0,0,0"
                                       VerticalAlignment="Center"
                                       FontSize="10"
                                       Foreground="#FFA39EAD"
                                       Text="Enter 전송 · Shift+Enter 줄바꿈" />
                        </StackPanel>
                        <Button x:Name="SendButton"
                                DockPanel.Dock="Right"
                                Width="108"
                                Height="41"
                                Style="{StaticResource PrimaryButton}"
                                Click="SendButton_Click"
                                Content="보내기  ↗" />
                    </DockPanel>
                </Grid>
            </Border>

            <TextBlock Grid.Row="2"
                       Margin="0,10,2,0"
                       HorizontalAlignment="Right"
                       FontSize="10"
                       Foreground="#FFA39EAD"
                       Text="대화는 이 PC에만 조용히 저장돼요" />
        </Grid>

        <ScrollViewer x:Name="ApiKeySettingsView"
                      Grid.Column="1"
                      Margin="28,22,28,18"
                      HorizontalScrollBarVisibility="Disabled"
                      VerticalScrollBarVisibility="Auto"
                      Visibility="Collapsed">
            <Grid MaxWidth="820" HorizontalAlignment="Center">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Grid Grid.Row="0" Margin="2,0,2,20">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel>
                        <TextBlock FontSize="27"
                                   FontWeight="Bold"
                                   Foreground="{StaticResource InkBrush}"
                                   Text="API 키 설정" />
                        <TextBlock Margin="1,6,0,0"
                                   Foreground="{StaticResource MutedBrush}"
                                   Text="사용할 AI의 키를 한곳에서 편하게 관리해요 🔐" />
                    </StackPanel>
                    <Button Grid.Column="1"
                            Height="38"
                            Padding="14,6"
                            VerticalAlignment="Center"
                            Style="{StaticResource PillButton}"
                            Click="BackToChatButton_Click"
                            Content="←  채팅으로 돌아가기" />
                </Grid>

                <Border Grid.Row="1"
                        Margin="0,0,0,14"
                        Padding="16,13"
                        Background="{StaticResource PrimarySoftBrush}"
                        CornerRadius="15">
                    <DockPanel>
                        <TextBlock Margin="0,0,10,0"
                                   VerticalAlignment="Center"
                                   FontSize="17"
                                   Text="🛡️" />
                        <TextBlock VerticalAlignment="Center"
                                   FontSize="12"
                                   Foreground="#FF5D51C6"
                                   Text="저장한 키는 이 PC의 Windows 자격 증명 관리자에 보관돼요. 대화 기록에는 들어가지 않아요."
                                   TextWrapping="Wrap" />
                    </DockPanel>
                </Border>

                <StackPanel Grid.Row="2">
                    <Border Margin="0,0,0,12"
                            Padding="18"
                            Background="{StaticResource CardBrush}"
                            BorderBrush="{StaticResource BorderBrush}"
                            BorderThickness="1"
                            CornerRadius="19">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Border Width="44" Height="44" Margin="0,0,15,0"
                                    VerticalAlignment="Top" Background="#FFEAF2FF" CornerRadius="14">
                                <TextBlock HorizontalAlignment="Center" VerticalAlignment="Center"
                                           FontSize="19" Text="✦" />
                            </Border>
                            <StackPanel Grid.Column="1">
                                <DockPanel Margin="1,0,1,9" LastChildFill="False">
                                    <TextBlock FontSize="16" FontWeight="Bold"
                                               Foreground="{StaticResource InkBrush}" Text="Google Gemini" />
                                    <TextBlock x:Name="GeminiApiKeyStatusText" DockPanel.Dock="Right"
                                               VerticalAlignment="Center" FontSize="11" FontWeight="SemiBold"
                                               Foreground="{StaticResource MutedBrush}" Text="입력 필요" />
                                </DockPanel>
                                <Border Height="44" Background="#FFFCFBFE" BorderBrush="{StaticResource BorderBrush}"
                                        BorderThickness="1" CornerRadius="13">
                                    <PasswordBox x:Name="GeminiApiKeyBox"
                                                 AutomationProperties.Name="Google Gemini API 키"
                                                 Style="{StaticResource RoundedPasswordBox}"
                                                 VerticalContentAlignment="Center" />
                                </Border>
                                <TextBlock Margin="2,7,0,0" FontSize="10.5"
                                           Foreground="{StaticResource MutedBrush}"
                                           Text="Google AI Studio에서 발급한 키" />
                            </StackPanel>
                        </Grid>
                    </Border>

                    <Border Margin="0,0,0,12"
                            Padding="18"
                            Background="{StaticResource CardBrush}"
                            BorderBrush="{StaticResource BorderBrush}"
                            BorderThickness="1"
                            CornerRadius="19">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Border Width="44" Height="44" Margin="0,0,15,0"
                                    VerticalAlignment="Top" Background="#FFEBF7F0" CornerRadius="14">
                                <TextBlock HorizontalAlignment="Center" VerticalAlignment="Center"
                                           FontSize="18" Text="◎" />
                            </Border>
                            <StackPanel Grid.Column="1">
                                <DockPanel Margin="1,0,1,9" LastChildFill="False">
                                    <TextBlock FontSize="16" FontWeight="Bold"
                                               Foreground="{StaticResource InkBrush}" Text="OpenAI GPT" />
                                    <TextBlock x:Name="OpenAiApiKeyStatusText" DockPanel.Dock="Right"
                                               VerticalAlignment="Center" FontSize="11" FontWeight="SemiBold"
                                               Foreground="{StaticResource MutedBrush}" Text="입력 필요" />
                                </DockPanel>
                                <Border Height="44" Background="#FFFCFBFE" BorderBrush="{StaticResource BorderBrush}"
                                        BorderThickness="1" CornerRadius="13">
                                    <PasswordBox x:Name="OpenAiApiKeyBox"
                                                 AutomationProperties.Name="OpenAI API 키"
                                                 Style="{StaticResource RoundedPasswordBox}"
                                                 VerticalContentAlignment="Center" />
                                </Border>
                                <TextBlock Margin="2,7,0,0" FontSize="10.5"
                                           Foreground="{StaticResource MutedBrush}"
                                           Text="OpenAI Platform에서 발급한 키" />
                            </StackPanel>
                        </Grid>
                    </Border>

                    <Border Padding="18"
                            Background="{StaticResource CardBrush}"
                            BorderBrush="{StaticResource BorderBrush}"
                            BorderThickness="1"
                            CornerRadius="19">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Border Width="44" Height="44" Margin="0,0,15,0"
                                    VerticalAlignment="Top" Background="#FFFFF0E8" CornerRadius="14">
                                <TextBlock HorizontalAlignment="Center" VerticalAlignment="Center"
                                           FontSize="18" Text="✺" />
                            </Border>
                            <StackPanel Grid.Column="1">
                                <DockPanel Margin="1,0,1,9" LastChildFill="False">
                                    <TextBlock FontSize="16" FontWeight="Bold"
                                               Foreground="{StaticResource InkBrush}" Text="Anthropic Claude" />
                                    <TextBlock x:Name="AnthropicApiKeyStatusText" DockPanel.Dock="Right"
                                               VerticalAlignment="Center" FontSize="11" FontWeight="SemiBold"
                                               Foreground="{StaticResource MutedBrush}" Text="입력 필요" />
                                </DockPanel>
                                <Border Height="44" Background="#FFFCFBFE" BorderBrush="{StaticResource BorderBrush}"
                                        BorderThickness="1" CornerRadius="13">
                                    <PasswordBox x:Name="AnthropicApiKeyBox"
                                                 AutomationProperties.Name="Anthropic API 키"
                                                 Style="{StaticResource RoundedPasswordBox}"
                                                 VerticalContentAlignment="Center" />
                                </Border>
                                <TextBlock Margin="2,7,0,0" FontSize="10.5"
                                           Foreground="{StaticResource MutedBrush}"
                                           Text="Anthropic Console에서 발급한 키" />
                            </StackPanel>
                        </Grid>
                    </Border>

                    <Border Margin="0,12,0,0"
                            Padding="17"
                            Background="{StaticResource PinkSoftBrush}"
                            CornerRadius="19">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <DockPanel>
                                <Border Width="42" Height="42" Margin="0,0,14,0"
                                        Background="White" CornerRadius="13">
                                    <TextBlock HorizontalAlignment="Center" VerticalAlignment="Center"
                                               FontSize="18" Text="🧳" />
                                </Border>
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock FontSize="15" FontWeight="Bold"
                                               Foreground="{StaticResource InkBrush}"
                                               Text="다른 PC로 키 옮기기" />
                                    <TextBlock Margin="0,3,0,0" FontSize="10.5"
                                               FontWeight="SemiBold"
                                               Foreground="#FFC0475D"
                                               Text="⚠ 암호화되지 않아요. 파일을 가진 사람은 API 키를 볼 수 있어요."
                                               TextWrapping="Wrap" />
                                </StackPanel>
                            </DockPanel>
                            <StackPanel Grid.Row="1"
                                        Margin="56,13,0,0"
                                        Orientation="Horizontal">
                                <Button x:Name="ExportKeyPresetButton"
                                        Height="36"
                                        Padding="13,5"
                                        Style="{StaticResource PillButton}"
                                        Click="ExportKeyPresetButton_Click"
                                        Content="파일로 저장" />
                                <Button x:Name="ImportKeyPresetButton"
                                        Height="36"
                                        Margin="8,0,0,0"
                                        Padding="13,5"
                                        Style="{StaticResource SoftButton}"
                                        Click="ImportKeyPresetButton_Click"
                                        Content="프리셋 불러오기" />
                            </StackPanel>
                        </Grid>
                    </Border>
                </StackPanel>

                <Grid Grid.Row="3" Margin="2,16,2,4">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock x:Name="ApiKeySettingsNotice"
                               VerticalAlignment="Center"
                               FontSize="11"
                               Foreground="{StaticResource MutedBrush}"
                               Text="키를 지운 채 저장하면 해당 키도 Windows에서 삭제돼요."
                               TextWrapping="Wrap" />
                    <Button x:Name="SaveAllApiKeysButton"
                            Grid.Column="1"
                            Width="150"
                            Height="43"
                            Margin="18,0,0,0"
                            Style="{StaticResource PrimaryButton}"
                            Click="SaveAllApiKeysButton_Click"
                            Content="모두 저장하기" />
                </Grid>
            </Grid>
        </ScrollViewer>

        <Grid x:Name="UsageView"
              Grid.Column="1"
              Margin="28,22,28,18"
              MaxWidth="900"
              HorizontalAlignment="Stretch"
              Visibility="Collapsed">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Grid Grid.Row="0" Margin="2,0,2,20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel>
                    <TextBlock FontSize="27"
                               FontWeight="Bold"
                               Foreground="{StaticResource InkBrush}"
                               Text="예상 사용료" />
                    <TextBlock Margin="1,6,0,0"
                               Foreground="{StaticResource MutedBrush}"
                               Text="이번 달에 AI를 얼마나 사용했는지 가볍게 확인해요 💸" />
                </StackPanel>
                <StackPanel Grid.Column="1"
                            Orientation="Horizontal"
                            VerticalAlignment="Center">
                    <Button x:Name="CompareSubscriptionsButton"
                            Height="38"
                            Margin="0,0,8,0"
                            Padding="14,6"
                            Style="{StaticResource SoftButton}"
                            Click="CompareSubscriptionsButton_Click"
                            Content="구독과 비교하기" />
                    <Button Height="38"
                            Padding="14,6"
                            Style="{StaticResource PillButton}"
                            Click="BackToChatButton_Click"
                            Content="←  채팅으로 돌아가기" />
                </StackPanel>
            </Grid>

            <Border Grid.Row="1"
                    Margin="0,0,0,16"
                    Padding="24,21"
                    CornerRadius="22">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Offset="0" Color="#FF7567E8" />
                        <GradientStop Offset="0.55" Color="#FF8B78EB" />
                        <GradientStop Offset="1" Color="#FFCF7FA9" />
                    </LinearGradientBrush>
                </Border.Background>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel>
                        <TextBlock FontSize="12"
                                   FontWeight="SemiBold"
                                   Foreground="#DDFFFFFF"
                                   Text="이달의 예상 합계" />
                        <TextBlock x:Name="UsageTotalText"
                                   Margin="0,5,0,0"
                                   FontSize="34"
                                   FontWeight="Bold"
                                   Foreground="White"
                                   Text="₩0.00" />
                        <TextBlock x:Name="UsageExchangeRateText"
                                   Margin="1,7,0,0"
                                   FontSize="10.5"
                                   Foreground="#CCFFFFFF"
                                   Text="ECB 환율 확인 중…" />
                    </StackPanel>
                    <Border Grid.Column="1"
                            MinWidth="94"
                            Margin="20,0,0,0"
                            Padding="15,10"
                            VerticalAlignment="Center"
                            Background="#2AFFFFFF"
                            CornerRadius="15">
                        <StackPanel HorizontalAlignment="Center">
                            <TextBlock HorizontalAlignment="Center"
                                       FontSize="24"
                                       Text="🐇" />
                            <TextBlock x:Name="UsageRequestCountText"
                                       Margin="0,4,0,0"
                                       HorizontalAlignment="Center"
                                       FontSize="11"
                                       FontWeight="SemiBold"
                                       Foreground="White"
                                       Text="0번 사용" />
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>

            <Grid Grid.Row="2" Margin="2,0,2,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <Button x:Name="PreviousUsageMonthButton"
                        Width="42"
                        Height="36"
                        Padding="0"
                        Style="{StaticResource PillButton}"
                        Click="PreviousUsageMonthButton_Click"
                        Content="‹" />
                <TextBlock x:Name="UsageMonthText"
                           Grid.Column="1"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           FontSize="16"
                           FontWeight="Bold"
                           Foreground="{StaticResource InkBrush}"
                           Text="2026년 7월" />
                <Button x:Name="NextUsageMonthButton"
                        Grid.Column="2"
                        Width="42"
                        Height="36"
                        Padding="0"
                        Style="{StaticResource PillButton}"
                        Click="NextUsageMonthButton_Click"
                        Content="›" />
            </Grid>

            <Border Grid.Row="3"
                    Background="{StaticResource CardBrush}"
                    BorderBrush="{StaticResource BorderBrush}"
                    BorderThickness="1"
                    CornerRadius="20">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <Grid Margin="20,14,20,11">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="180" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="150" />
                        </Grid.ColumnDefinitions>
                        <TextBlock FontSize="11"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource MutedBrush}"
                                   Text="날짜" />
                        <TextBlock Grid.Column="1"
                                   FontSize="11"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource MutedBrush}"
                                   Text="모델명" />
                        <TextBlock Grid.Column="2"
                                   HorizontalAlignment="Right"
                                   FontSize="11"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource MutedBrush}"
                                   Text="금액" />
                    </Grid>

                    <ScrollViewer Grid.Row="1"
                                  HorizontalScrollBarVisibility="Disabled"
                                  VerticalScrollBarVisibility="Auto">
                        <ItemsControl ItemsSource="{Binding UsageItems}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Margin="12,0,12,8"
                                            Padding="10,13"
                                            Background="#FFFCFBFE"
                                            CornerRadius="13">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="158" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="138" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock VerticalAlignment="Center"
                                                       FontSize="12"
                                                       Foreground="{StaticResource MutedBrush}"
                                                       Text="{Binding DateLabel}" />
                                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                <TextBlock FontSize="13"
                                                           FontWeight="SemiBold"
                                                           Foreground="{StaticResource InkBrush}"
                                                           Text="{Binding ModelName}"
                                                           TextTrimming="CharacterEllipsis" />
                                                <TextBlock Margin="0,3,0,0"
                                                           FontSize="9.5"
                                                           Foreground="{StaticResource MutedBrush}"
                                                           Text="{Binding ProviderLabel}" />
                                            </StackPanel>
                                            <TextBlock Grid.Column="2"
                                                       HorizontalAlignment="Right"
                                                       VerticalAlignment="Center"
                                                       FontSize="13"
                                                       FontWeight="Bold"
                                                       Foreground="{StaticResource PrimaryBrush}"
                                                       Text="{Binding AmountLabel}" />
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>

                    <StackPanel x:Name="UsageEmptyState"
                                Grid.Row="1"
                                Margin="20"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center">
                        <TextBlock HorizontalAlignment="Center"
                                   FontSize="30"
                                   Text="🌱" />
                        <TextBlock Margin="0,9,0,0"
                                   HorizontalAlignment="Center"
                                   FontSize="14"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource InkBrush}"
                                   Text="아직 기록된 사용료가 없어요" />
                        <TextBlock Margin="0,5,0,0"
                                   HorizontalAlignment="Center"
                                   FontSize="11"
                                   Foreground="{StaticResource MutedBrush}"
                                   Text="이 기능을 켠 뒤 완료된 새 요청부터 차곡차곡 보여요" />
                    </StackPanel>
                </Grid>
            </Border>

            <TextBlock Grid.Row="4"
                       Margin="3,10,3,0"
                       HorizontalAlignment="Right"
                       FontSize="10"
                       Foreground="#FFA39EAD"
                       Text="공식 단가 기준 예상치예요 · 무료 한도, 세금, 환율 변동은 실제 청구와 다를 수 있어요" />
        </Grid>

        <ScrollViewer x:Name="ManualView"
                      Grid.Column="1"
                      Margin="28,22,28,18"
                      HorizontalScrollBarVisibility="Disabled"
                      VerticalScrollBarVisibility="Auto"
                      Visibility="Collapsed">
            <ScrollViewer.Resources>
                <Style TargetType="ScrollBar" BasedOn="{StaticResource SlimScrollBar}" />
            </ScrollViewer.Resources>

            <StackPanel MaxWidth="900" HorizontalAlignment="Center">
                <Grid Margin="2,0,2,20">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel>
                        <TextBlock FontSize="27"
                                   FontWeight="Bold"
                                   Foreground="{StaticResource InkBrush}"
                                   Text="Bunny Desk 사용법" />
                        <TextBlock Margin="1,6,0,0"
                                   Foreground="{StaticResource MutedBrush}"
                                   Text="처음 쓰기 전에 꼭 알아둘 것만 토끼 선생님이 알려드려요 ✨" />
                    </StackPanel>
                    <Button Grid.Column="1"
                            Height="38"
                            Padding="14,6"
                            VerticalAlignment="Center"
                            Style="{StaticResource PillButton}"
                            Click="BackToChatButton_Click"
                            Content="←  채팅으로 돌아가기" />
                </Grid>

                <Border Padding="24"
                        Background="#FFFFEFF6"
                        CornerRadius="25">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="18"
                                          Opacity="0.07"
                                          ShadowDepth="4"
                                          Color="#FF9B5577" />
                    </Border.Effect>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="220" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Border Width="210"
                                Height="210"
                                HorizontalAlignment="Left"
                                VerticalAlignment="Center"
                                Background="#80FFFFFF"
                                CornerRadius="28">
                            <Image Margin="-7"
                                   Stretch="Uniform"
                                   Source="/GeminiDesk;component/Assets/bunny-guide.png" />
                        </Border>
                        <StackPanel Grid.Column="1"
                                    Margin="24,0,0,0"
                                    VerticalAlignment="Center">
                            <Border Padding="9,4"
                                    HorizontalAlignment="Left"
                                    Background="#FFFFFFFF"
                                    CornerRadius="9">
                                <TextBlock FontSize="9.5"
                                           FontWeight="Bold"
                                           Foreground="#FFB04C75"
                                           Text="BUNNY DESK GUIDE" />
                            </Border>
                            <TextBlock Margin="0,12,0,0"
                                       FontSize="23"
                                       FontWeight="Bold"
                                       Foreground="{StaticResource InkBrush}"
                                       Text="토끼 선생님의 1분 안내" />
                            <TextBlock Margin="0,9,0,0"
                                       FontSize="12.5"
                                       Foreground="{StaticResource MutedBrush}"
                                       LineHeight="22"
                                       Text="API는 공홈 구독과 사용 방식이 달라요.&#10;키를 안전하게 지키고, 대화 주제마다 새 채팅을 만드는 것부터 시작해요."
                                       TextWrapping="Wrap" />
                        </StackPanel>
                    </Grid>
                </Border>

                <TextBlock Margin="3,25,3,11"
                           FontSize="20"
                           FontWeight="Bold"
                           Foreground="{StaticResource InkBrush}"
                           Text="꼭 읽어주세요" />

                <Border Margin="0,0,0,10"
                        Padding="18"
                        Background="#FFFFEDF2"
                        BorderBrush="#FFFFD0DC"
                        BorderThickness="1"
                        CornerRadius="17">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="44" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock HorizontalAlignment="Center"
                                   VerticalAlignment="Top"
                                   FontSize="22"
                                   Text="🔐" />
                        <StackPanel Grid.Column="1">
                            <TextBlock FontSize="14"
                                       FontWeight="Bold"
                                       Foreground="#FF9A3F5A"
                                       Text="API KEY는 비밀번호처럼 다뤄주세요" />
                            <TextBlock Margin="0,5,0,0"
                                       FontSize="12"
                                       Foreground="{StaticResource InkBrush}"
                                       LineHeight="21"
                                       Text="API KEY와 KEY PRESET 파일은 절대로 남에게 공유하지 마세요."
                                       TextWrapping="Wrap" />
                        </StackPanel>
                    </Grid>
                </Border>

                <Border Margin="0,0,0,10"
                        Padding="18"
                        Background="#FFF5F3FF"
                        CornerRadius="17">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="44" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock HorizontalAlignment="Center"
                                   VerticalAlignment="Top"
                                   FontSize="22"
                                   Text="💳" />
                        <StackPanel Grid.Column="1">
                            <TextBlock FontSize="14"
                                       FontWeight="Bold"
                                       Foreground="#FF5D51C6"
                                       Text="공홈 구독과 API 사용은 많이 달라요" />
                            <TextBlock Margin="0,5,0,0"
                                       FontSize="12"
                                       Foreground="{StaticResource InkBrush}"
                                       LineHeight="21"
                                       Text="Bunny Desk는 API를 사용하는 프로그램이에요. 요청마다 입력·출력 토큰(문자와 단어를 잘게 나눈 단위) 등의 사용량으로 비용이 매겨지고 모델마다 가격도 달라요. 각 플랫폼 공홈의 편리한 기능을 연동할 수 없으며, AI는 다른 채팅방의 당신에 관한 정보를 기억하지 않아요. 채팅방(세션)이 바뀌면 AI도 새로 시작해요."
                                       TextWrapping="Wrap" />
                        </StackPanel>
                    </Grid>
                </Border>

                <Border Margin="0,0,0,10"
                        Padding="18"
                        Background="#FFFFF8E8"
                        CornerRadius="17">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="44" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock HorizontalAlignment="Center"
                                   VerticalAlignment="Top"
                                   FontSize="22"
                                   Text="🧹" />
                        <StackPanel Grid.Column="1">
                            <TextBlock FontSize="14"
                                       FontWeight="Bold"
                                       Foreground="#FF9C6B14"
                                       Text="한 채팅방에 모든 대화를 쌓지 마세요" />
                            <TextBlock Margin="0,5,0,0"
                                       FontSize="12"
                                       Foreground="{StaticResource InkBrush}"
                                       LineHeight="21"
                                       Text="대화가 길어질수록 함께 보내는 문맥도 늘어나 요금이 비싸질 수 있어요. 하나의 대화 주제가 끝나면 새 채팅방을 만드는 습관을 들이면 좋아요."
                                       TextWrapping="Wrap" />
                        </StackPanel>
                    </Grid>
                </Border>

                <UniformGrid Columns="3" Margin="-5,0,-5,0">
                    <Border Margin="5"
                            Padding="16"
                            Background="#FFF0F8FF"
                            CornerRadius="17">
                        <StackPanel>
                            <TextBlock FontSize="21" Text="✨" />
                            <TextBlock Margin="0,8,0,0"
                                       FontSize="13"
                                       FontWeight="Bold"
                                       Foreground="{StaticResource InkBrush}"
                                       Text="새 모델 업데이트" />
                            <TextBlock Margin="0,5,0,0"
                                       FontSize="11"
                                       Foreground="{StaticResource MutedBrush}"
                                       LineHeight="19"
                                       Text="새 모델이 출시되면 재설치 없이 제작자가 원격으로 목록을 업데이트할 수 있어요."
                                       TextWrapping="Wrap" />
                        </StackPanel>
                    </Border>
                    <Border Margin="5"
                            Padding="16"
                            Background="#FFF4F1FF"
                            CornerRadius="17">
                        <StackPanel>
                            <TextBlock FontSize="21" Text="🧠" />
                            <TextBlock Margin="0,8,0,0"
                                       FontSize="13"
                                       FontWeight="Bold"
                                       Foreground="{StaticResource InkBrush}"
                                       Text="Gemini 3.1 Pro" />
                            <TextBlock Margin="0,5,0,0"
                                       FontSize="11"
                                       Foreground="{StaticResource MutedBrush}"
                                       LineHeight="19"
                                       Text="추론 강도를 최대로 설정해 두었어요."
                                       TextWrapping="Wrap" />
                        </StackPanel>
                    </Border>
                    <Border Margin="5"
                            Padding="16"
                            Background="#FFFFF0F5"
                            CornerRadius="17">
                        <StackPanel>
                            <TextBlock FontSize="21" Text="✍️" />
                            <TextBlock Margin="0,8,0,0"
                                       FontSize="13"
                                       FontWeight="Bold"
                                       Foreground="{StaticResource InkBrush}"
                                       Text="Claude Opus 4.6" />
                            <TextBlock Margin="0,5,0,0"
                                       FontSize="11"
                                       Foreground="{StaticResource MutedBrush}"
                                       LineHeight="19"
                                       Text="타사 대비 가격·성능 메리트가 크지 않다고 판단해, 제일 귀여운 Opus 4.6만 제공해요."
                                       TextWrapping="Wrap" />
                        </StackPanel>
                    </Border>
                </UniformGrid>

                <DockPanel Margin="3,25,3,11" LastChildFill="False">
                    <TextBlock VerticalAlignment="Center"
                               FontSize="20"
                               FontWeight="Bold"
                               Foreground="{StaticResource InkBrush}"
                               Text="모델 선택 가이드" />
                    <Button x:Name="DetailedModelGuideButton"
                            DockPanel.Dock="Right"
                            Height="34"
                            Padding="13,5"
                            Style="{StaticResource SoftButton}"
                            Click="DetailedModelGuideButton_Click"
                            Content="상세 모델 가이드  →" />
                </DockPanel>

                <UniformGrid Columns="2" Margin="-5,0,-5,0">
                    <Border Margin="5"
                            Padding="18"
                            Background="#FFFFF8E8"
                            CornerRadius="18">
                        <StackPanel>
                            <TextBlock FontSize="22" Text="⚡" />
                            <TextBlock Margin="0,8,0,0"
                                       FontSize="15"
                                       FontWeight="Bold"
                                       Foreground="{StaticResource InkBrush}"
                                       Text="간단한 작업" />
                            <TextBlock Margin="0,6,0,0"
                                       FontSize="11.5"
                                       Foreground="{StaticResource MutedBrush}"
                                       LineHeight="20"
                                       Text="Gemini 공홈에서 3.5 Flash를 무료로 사용하세요. Bunny Desk에서는 가장 저렴한 GPT Luna도 좋아요."
                                       TextWrapping="Wrap" />
                        </StackPanel>
                    </Border>
                    <Border Margin="5"
                            Padding="18"
                            Background="#FFF0F8FF"
                            CornerRadius="18">
                        <StackPanel>
                            <TextBlock FontSize="22" Text="🌎" />
                            <TextBlock Margin="0,8,0,0"
                                       FontSize="15"
                                       FontWeight="Bold"
                                       Foreground="{StaticResource InkBrush}"
                                       Text="범용 작업" />
                            <TextBlock Margin="0,6,0,0"
                                       FontSize="11.5"
                                       Foreground="{StaticResource MutedBrush}"
                                       LineHeight="20"
                                       Text="어디에나 무난하게 쓰기 좋은 균형형 모델은 GPT Terra예요."
                                       TextWrapping="Wrap" />
                        </StackPanel>
                    </Border>
                    <Border Margin="5"
                            Padding="18"
                            Background="#FFF4F1FF"
                            CornerRadius="18">
                        <StackPanel>
                            <TextBlock FontSize="22" Text="🧩" />
                            <TextBlock Margin="0,8,0,0"
                                       FontSize="15"
                                       FontWeight="Bold"
                                       Foreground="{StaticResource InkBrush}"
                                       Text="추론이 필요한 작업" />
                            <TextBlock Margin="0,6,0,0"
                                       FontSize="11.5"
                                       Foreground="{StaticResource MutedBrush}"
                                       LineHeight="20"
                                       Text="Gemini 3.1 Pro 또는 GPT Sol을 사용하세요. GPT가 훨씬 똑똑하지만 조금 더 비싸요."
                                       TextWrapping="Wrap" />
                        </StackPanel>
                    </Border>
                    <Border Margin="5"
                            Padding="18"
                            Background="#FFFFEEF4"
                            CornerRadius="18">
                        <StackPanel>
                            <TextBlock FontSize="22" Text="💗" />
                            <TextBlock Margin="0,8,0,0"
                                       FontSize="15"
                                       FontWeight="Bold"
                                       Foreground="{StaticResource InkBrush}"
                                       Text="상담·감성·글쓰기" />
                            <TextBlock Margin="0,6,0,0"
                                       FontSize="11.5"
                                       Foreground="{StaticResource MutedBrush}"
                                       LineHeight="20"
                                       Text="상담, 감성 대화, 글쓰기와 문과생 작업에는 Claude Opus 4.6을 추천해요."
                                       TextWrapping="Wrap" />
                        </StackPanel>
                    </Border>
                </UniformGrid>

                <Border Margin="0,16,0,4"
                        Padding="16,13"
                        Background="#FFFFFFFF"
                        BorderBrush="{StaticResource BorderBrush}"
                        BorderThickness="1"
                        CornerRadius="15">
                    <TextBlock HorizontalAlignment="Center"
                               FontSize="11.5"
                               Foreground="{StaticResource MutedBrush}"
                               Text="어떤 모델을 고를지 헷갈리면 GPT Terra부터 시작해 보세요 🐇" />
                </Border>
            </StackPanel>
        </ScrollViewer>

        <local:DetailedModelGuideView x:Name="ModelGuideView"
                                      Grid.Column="1"
                                      Visibility="Collapsed"
                                      BackRequested="ModelGuideView_BackRequested" />
    </Grid>
</Window>
